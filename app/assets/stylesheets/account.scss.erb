// =============================================================================
// Account Page — Private settings
// =============================================================================
// BEM structure: .xw-account-header, .xw-account-section, .xw-account-photo.
// Uses design tokens exclusively. Mirrors profile page's visual hierarchy:
// header is the dominant element (paper texture, shadow), sections are
// subordinate (clean white cards).
// =============================================================================

@import 'design_tokens';

// -----------------------------------------------------------------------------
// Page-level: warmer container bg so white cards pop (matches profile)
// -----------------------------------------------------------------------------

#body > .xw-container.xw-grid {
  background-color: var(--color-surface-alt);
  gap: var(--space-6);
  padding-top: var(--space-6);
  padding-bottom: var(--space-8);
}

// -----------------------------------------------------------------------------
// Account Header — compact identity banner (mini-hero)
// -----------------------------------------------------------------------------

.xw-account-header {
  display: flex;
  align-items: center;
  gap: var(--space-5);
  padding: var(--space-6);
  background-color: var(--color-bg-warm);
  background-image: url("<%= asset_path 'paper.jpeg' %>");
  background-size: cover;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-paper);
  border-top: 3px solid var(--color-accent);
}

.xw-account-header__avatar {
  flex-shrink: 0;

  img {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    border: 2px solid var(--color-border-strong);
    box-shadow: var(--shadow-md);
    object-fit: cover;
  }
}

.xw-account-header__info {
  flex: 1;
  min-width: 0;
}

.xw-account-header__name {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: var(--weight-bold);
  color: var(--color-text);
  margin: 0 0 var(--space-1) 0;
  line-height: var(--leading-tight);
}

.xw-account-header__meta {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin: 0;
}

.xw-account-header__dot {
  margin: 0 var(--space-1);
}

// Mobile: stack vertically, center
@media (max-width: #{$bp-sm - 1}) {
  .xw-account-header {
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-5) var(--space-4);
  }

  .xw-account-header__name {
    font-size: var(--text-2xl);
  }
}

// -----------------------------------------------------------------------------
// Section Cards — grouped form areas
// -----------------------------------------------------------------------------

.xw-account-section {
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  margin-bottom: var(--space-5);

  &:last-child {
    margin-bottom: 0;
  }
}

.xw-account-section__heading {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wider);
  margin: 0 0 var(--space-5) 0;
  padding-bottom: var(--space-3);
  border-bottom: 1px solid var(--color-border);
}

.xw-account-section__actions {
  padding-top: var(--space-2);
}

.xw-account-section__empty {
  font-family: var(--font-body);
  font-style: italic;
  color: var(--color-text-muted);
}

// Mobile: tighter section padding
@media (max-width: #{$bp-sm - 1}) {
  .xw-account-section {
    padding: var(--space-4);
  }
}

// -----------------------------------------------------------------------------
// Profile Photo — avatar preview + upload controls side by side
// -----------------------------------------------------------------------------

.xw-account-photo {
  display: flex;
  gap: var(--space-6);
  align-items: flex-start;
}

.xw-account-photo__preview {
  flex-shrink: 0;

  img {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-full);
    border: 2px solid var(--color-border-strong);
    box-shadow: var(--shadow-md);
    object-fit: cover;
    background-color: var(--color-surface-sunken);
  }
}

.xw-account-photo__controls {
  flex: 1;
  min-width: 0;

  // Tighten spacing between upload fields
  .xw-field {
    margin-bottom: var(--space-3);
  }
}

.xw-account-photo__divider {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin: var(--space-2) 0;

  &::before,
  &::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: var(--color-border);
  }

  span {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    white-space: nowrap;
  }
}

// File input: styled to match design system
.xw-input--file {
  padding: var(--space-2);
  font-size: var(--text-sm);
  cursor: pointer;

  &::file-selector-button {
    padding: var(--space-1) var(--space-3);
    margin-right: var(--space-3);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background-color: var(--color-surface-alt);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: var(--transition-colors);

    &:hover {
      background-color: var(--color-surface-sunken);
      border-color: var(--color-accent);
      color: var(--color-text);
    }
  }
}

// Mobile: stack photo preview and controls
@media (max-width: #{$bp-sm - 1}) {
  .xw-account-photo {
    flex-direction: column;
    align-items: center;
  }

  .xw-account-photo__controls {
    width: 100%;
  }
}

// -----------------------------------------------------------------------------
// Form Grid — two-column layout for name fields
// -----------------------------------------------------------------------------

.xw-account-form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 var(--space-4);
}

@media (max-width: #{$bp-sm - 1}) {
  .xw-account-form-grid {
    grid-template-columns: 1fr;
  }
}

// -----------------------------------------------------------------------------
// Alert close button (carried over, refined)
// -----------------------------------------------------------------------------

.slide-close {
  font-size: 1.375rem;
  padding: 9px 6px 4px;
  line-height: 0;
  position: absolute;
  top: var(--space-2);
  right: var(--space-2);
  color: var(--color-text);
  opacity: 0.3;
  background: none;
  border: none;
  cursor: pointer;

  &:hover,
  &:focus { opacity: 0.5; }
}

// -----------------------------------------------------------------------------
// Notification Preferences — checkbox list
// -----------------------------------------------------------------------------

.xw-account-section__hint {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin: 0 0 var(--space-4);
}

.xw-account-notification-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.xw-account-notification-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.xw-checkbox {
  appearance: none;
  -webkit-appearance: none;
  width: 18px;
  height: 18px;
  border: 2px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  background-color: var(--color-surface);
  cursor: pointer;
  flex-shrink: 0;
  transition: var(--transition-colors);
  position: relative;

  &:checked {
    background-color: var(--color-accent);
    border-color: var(--color-accent);

    &::after {
      content: '';
      position: absolute;
      left: 4px;
      top: 1px;
      width: 5px;
      height: 9px;
      border: solid var(--color-surface);
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }
  }

  &:focus-visible {
    box-shadow: 0 0 0 3px var(--color-accent-light);
  }
}

.xw-checkbox-label {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-text);
  cursor: pointer;
}

// -----------------------------------------------------------------------------
// Danger Zone — destructive actions (delete account)
// -----------------------------------------------------------------------------

.xw-account-section--danger {
  border-left: 3px solid var(--color-danger);

  .xw-account-section__heading {
    color: var(--color-danger-text);
  }
}
