// Phase 1: all nav styles moved to _nav.scss
// Phase 5: footer styles will be migrated to _components.scss / _footer.scss

footer#footer {
  position: relative;
  background-color: var(--color-footer-bg);
  color: var(--color-footer-text);
  margin-top: 4em;
  padding-top: 0.75em;
  width: 100%;

  a {
    color: var(--color-footer-link);
    transition: all 0.3s;

    &:hover {
      color: var(--color-footer-link-hover);
    }
  }

  .xw-footer__copyright {
    margin-bottom: 0;
    color: var(--color-text-muted);
    font-weight: var(--weight-normal);
  }

  #social-links {
    i {
      color: var(--color-footer-link);
      font-size: 1.5em;
      transition: all 0.3s;
      &:hover {
        color: var(--color-footer-link-hover);
      }
    }
  }

  ul {
    list-style-type: none;
  }
}
