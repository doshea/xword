$bottomcolor: black;

.side-button {
  background: black;
  color: whitesmoke;
  font-size: 1.5em;

  #settings-button {
    position: fixed;
    right: 0;
    top: 40%;
    border-top-left-radius: 0.4em;
    border-bottom-left-radius: 0.4em;
    padding: 0.3em 0.3em 0.2em 0.4em;
  }
}

.bottom-button {
  background: black;
  color: whitesmoke;
  font-size: 1.25em;
  position: absolute;
  top: -1.5em;
  width: 6em;
  z-index: 1;
  border-top: 1px solid #444;
}
#ideas-button {
  border-top-right-radius: 0.5em;
  padding: 0.3em 0.4em 0.2em 0.3em;
  border-right: 1px solid #444;
}
#pattern-search-button {
  width: 9em;
  left: 5.8em;
  border-top-left-radius: 0.5em;
  padding: 0.3em 0.3em 0.2em 0.4em;
  border-left: 1px solid #444;
}

.slide-up-container {
  z-index: 70001;
  position: fixed;
  transition: top 0.4s;
  top: 100%;
  bottom: 0;
  height: 90%;

  &#idea-container {
    left: 0;
  }

  &#pattern-container {
    right: 0;
    width: 18.5em;
  }
  &.open{
    top: 95px;
  }
}
.xw-edit-header {
  display: flex;
  align-items: center;
  gap: 0.75em;
  flex-wrap: wrap;

  &__label {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  &__title {
    flex: 1;
    min-width: 10em;
    position: relative;

    input {
      width: 100%;
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: var(--weight-semibold);
      background: rgba(0, 0, 0, 0.03);
      border: none;
      border-bottom: 1px solid var(--color-border);
      border-radius: 0;
      padding: var(--space-1) var(--space-2);
      transition: border-color var(--duration-base) var(--ease-in-out);

      &:focus {
        border-bottom-color: var(--color-accent);
        box-shadow: none;
        outline: none;
      }
    }
  }

  #puzzle-controls {
    position: static;
    display: flex;
    align-items: center;
    gap: 0.5em;
    white-space: nowrap;

    .smaller {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }
  }
}

// Make edit-page clue inputs expand to fill the flexible column width.
// Overrides the text-indent hanging-indent with flexbox so the input
// takes all remaining space after the clue number.
.clue-column .clues .clue {
  display: flex;
  align-items: baseline;
  padding-left: 0.25em;
  text-indent: 0;

  &.hidden {
    display: none;
  }
}

.clue-column .clues .clue-num {
  flex-shrink: 0;
  min-width: 1.7em;
  text-align: right;
  margin-right: 0.3em;
}

.clue-column .clues textarea {
  flex: 1;
  min-width: 0;
  field-sizing: content;
  resize: none;
  overflow: hidden;
  border: none;
  box-shadow: none;
  background: none;
  margin-bottom: 0;
  padding: 0;
  font: inherit;
  cursor: pointer;
  &:focus {
    cursor: text;
  }
}

.xw-edit-switches {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.75em 1.5em;
}

#title {
  margin: 0;
}
#title-status {
  background-image: url("<%= asset_path 'spinner_small.gif' %>");
  position: absolute;
  top: 0;
  right: 1em;
  height: 100%;
  padding: 0 0.5em 0;
  color: black;
  opacity: 0;
  background-repeat: no-repeat;
  background-position: 50%;
  display: block;
  &.xw-status-err {
    color: var(--color-danger);
  }
  &.xw-status-err, &.xw-status-ok {
    background-image: none;
    padding: 0 0.2em 0;
  }
}

// On the edit page, #advanced is the last paper section (not #meta-area).
#meta-area { border-radius: 0; }
#advanced {
  border-bottom-left-radius: var(--radius-lg);
  border-bottom-right-radius: var(--radius-lg);
  border-top: 1px solid var(--color-border);

  h2 {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }
}

// Description label + textarea — match newspaper context
#meta-area {
  .xw-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
  }
  .xw-textarea {
    background-color: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-inner);
    border-radius: var(--radius-sm);
  }
}

#settings {
    color: whitesmoke;
    border-radius: 1px;
    background: $bottomcolor;
  }

#pattern-search {
  position: absolute;
  background: $bottomcolor;
  max-height: 80%;
  min-height: 20em;
  width: 18.5em;
  padding: 1em;
  border-left: 1px solid #444;
  border-bottom: 1px solid #444;
  border-top: 1px solid #444;

}

#word-match-results {
  background: white;
  overflow-y: auto;
  max-height: 25em;

  #match-header {
    text-align: center;
  }

  li {
    display: inline-block;
    font-size: small;

    &:hover {
      color: blue;
    }
  }
}

#pattern-search input, #ideas input {
  text-transform: uppercase;
  height: 2em;

  &::placeholder {
    text-transform: none;
  }
}

#ideas {
  position: absolute;
  text-transform: uppercase;
  background: $bottomcolor;
  max-height: 80%;
  min-height: 20em;
  width: 18.5em;
  padding: 1em;
  border-right: 1px solid #444;
  border-bottom: 1px solid #444;
  border-top: 1px solid #444;

  ul {
    background: white;
    overflow-y: auto;
    margin: 0;
    width: 16.5em;
    max-height: 25em;
    transition: max-height 0.4s;

    li {
      font-size: smaller;
      width: 100%;
      transition: background 0.4s;

      &:nth-child(even) {
        background: #eee;
      }

      &.added-word {
        background: lightgreen;
        display: none;
      }

      .length {
        opacity: 0.5;
        font-size: smaller;
        text-align: center;
      }
    }
  }
}
$switch-height: 1.8em;
$switch-width: 4em;
$pip-diameter: $switch-width/3;
$switch-on-color: lighten(limegreen, 20%);
$switch-off-color: lighten(red, 20%);
.switch-form {
  display: inline-block;
  margin: 0;
  height: $switch-height;
  position: relative;
  .switch {
    position: relative;
    width: $switch-width;
    background: white;
    height: $switch-height;
    display: inline-block;
    border-width: 1px;
    border-style: solid;
    border-radius: $pip-diameter;
    transition: all 0.2s;
  }
  .pip {
    position: absolute;
    display: inline-block;
    height: $pip-diameter;
    width: $pip-diameter;
    margin-top: $switch-height/14;
    border-radius: $pip-diameter/2;
    transition: all 0.2s;
  }
  label {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5em;
    width: auto;
    white-space: nowrap;
    &.on {
      .switch {
        border-color: $switch-on-color;
      }
      .pip {
        left: $switch-width*3/5;
        background: $switch-on-color;
      }
    }
    &.off {
      .switch {
        border-color: $switch-off-color;
      }
      .pip {
        left: $switch-width/15;
        background: $switch-off-color;
      }
    }
  }
  span {
    height: 1em;
    position: static;
  }
  input[type=checkbox] {
    display: none;
  }
}

#tools {
  position: fixed;
  height: 300px;
  width: 96%;
  margin: 0 2%;
  bottom: 0;
  z-index: 10000;
  background: rgba(30,30,30, 0.3);
  border-top-left-radius: 0.5em;
  border-top-right-radius: 0.5em;
  overflow: hidden;
  font-size: smaller;
}

.ui-draggable {
  cursor: grab;
  &.ui-draggable-dragging {
    cursor: grabbing;
  }
}

::-webkit-scrollbar {
    -webkit-appearance: none;
    width: 8px;
}

::-webkit-scrollbar-thumb {
    border-radius: 8px;
    border: 2px solid white; /* should match background, can't be transparent */
    background-color: rgba(0, 0, 0, .5);
}

@media (max-height: 700px){
  #ideas ul, #word-match-results {
    max-height: 15em;
  }
}
