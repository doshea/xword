@import 'design_tokens';

// --- Tool panel buttons ---


.bottom-button {
  background: var(--color-nav-bg);
  color: var(--color-nav-text);
  font-size: 1.25em;
  position: absolute;
  top: -1.5em;
  width: 6em;
  z-index: 1;
  border: none;
  border-top: 1px solid var(--color-nav-border);
  cursor: pointer;
  text-decoration: none; // prevent link-style underline leak
}
#ideas-button {
  border-top-right-radius: 0.5em;
  padding: 0.3em 0.4em 0.2em 0.3em;
  border-right: 1px solid var(--color-nav-border);
}
#pattern-search-button {
  width: 9em;
  left: 5.8em;
  border-top-left-radius: 0.5em;
  padding: 0.3em 0.3em 0.2em 0.4em;
  border-left: 1px solid var(--color-nav-border);
}

// --- Slide-up tool panels ---
// Panels anchor to bottom of viewport and slide up via `top` transition.
// Closed: top: 100% keeps panel below viewport, but .bottom-button tabs
// (at top: -1.5em) peek above the bottom edge as clickable handles.
// Open: top: 55% gives ~45vh of panel space — enough for search results
// while keeping the puzzle grid visible above.

.slide-up-container {
  z-index: var(--z-panel);
  position: fixed;
  transition: top 0.4s;
  top: 100%;
  bottom: 0;

  &#idea-container {
    left: 0;
  }

  &#pattern-container {
    right: 0;
    width: 18.5em;
  }
  &.open {
    top: 55%;
  }
}

// --- Edit header ---

.xw-edit-header {
  display: flex;
  align-items: center;
  gap: 0.75em;
  flex-wrap: wrap;
  width: 100%; // fill .xw-col-full so margin-left: auto on #puzzle-controls pushes right

  &__label {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  &__title {
    flex: 1;
    min-width: 10em;
    position: relative;

    input {
      width: 100%;
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: var(--weight-semibold);
      background: rgba(0, 0, 0, 0.03);
      border: none;
      border-bottom: 1px solid var(--color-border);
      border-radius: 0;
      padding: var(--space-1) var(--space-2);
      transition: border-color var(--duration-base) var(--ease-in-out);

      &:focus {
        border-bottom-color: var(--color-accent);
        box-shadow: none;
        outline: none;
      }
    }
  }

  #puzzle-controls {
    position: static;
    display: flex;
    align-items: center;
    gap: 0.5em;
    white-space: nowrap;
    margin-left: auto;

    .smaller {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }
  }
}

// --- Clue column (edit-page flexbox overrides) ---

.clue-column .clues .clue {
  display: flex;
  align-items: baseline;
  padding-left: 0.25em;
  text-indent: 0;

  &.hidden {
    display: none;
  }
}

.clue-column .clues .clue-num {
  flex-shrink: 0;
  min-width: 1.7em;
  text-align: right;
  margin-right: 0.3em;
}

.clue-column .clues textarea {
  flex: 1;
  min-width: 0;
  field-sizing: content;
  resize: none;
  overflow: hidden;
  border: none;
  box-shadow: none;
  background: none;
  margin-bottom: 0;
  padding: 0;
  font: inherit;
  cursor: pointer;
  &:focus {
    cursor: text;
  }
}

// --- Switches ---

.xw-edit-switches {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.75em 1.5em;
}

// --- Title input ---

#title {
  margin: 0;
}
#title-status {
  position: absolute;
  top: 0;
  right: 1em;
  height: 100%;
  padding: 0 0.5em;
  color: var(--color-text);
  opacity: 0;
  display: flex;
  align-items: center;
  &.xw-status-err {
    color: var(--color-danger);
  }
}

// --- Section overrides ---

// On the edit page, #advanced is the last paper section (not #meta-area).
#meta-area { border-radius: 0; }
#advanced {
  border-bottom-left-radius: var(--radius-lg);
  border-bottom-right-radius: var(--radius-lg);
  border-top: 2px solid var(--color-border-strong);
  padding-bottom: var(--space-2);
  margin-bottom: 2.5em; // clearance so fixed tool-panel tab buttons don't overlap footer

  h2 {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }
}

// Description label + textarea — match newspaper context
#meta-area {
  .xw-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
  }
  .xw-textarea {
    background-color: var(--color-surface-sunken);
    border: 1px solid transparent;
    box-shadow: var(--shadow-inner);
    border-radius: var(--radius-sm);
  }
}

// --- Tool panels ---

#pattern-search {
  position: absolute;
  background: var(--color-nav-bg);
  color: var(--color-nav-text);
  height: 100%;
  overflow-y: auto;
  width: 18.5em;
  padding: 1em;
  border-left: 1px solid var(--color-nav-border);
  border-bottom: 1px solid var(--color-nav-border);
  border-top: 1px solid var(--color-nav-border);
}

#word-match-results {
  background: var(--color-surface);
  overflow-y: auto;
  max-height: 25em;

  #match-header {
    text-align: center;
  }

  li {
    display: inline-block;
    font-size: small;
    color: var(--color-text);

    &:hover {
      color: var(--color-accent);
    }
  }
}

#pattern-search input, #ideas input {
  text-transform: uppercase;
  height: 2em;

  &::placeholder {
    text-transform: none;
  }
}

#ideas {
  position: absolute;
  text-transform: uppercase;
  background: var(--color-nav-bg);
  color: var(--color-nav-text);
  height: 100%;
  overflow-y: auto;
  width: 18.5em;
  padding: 1em;
  border-right: 1px solid var(--color-nav-border);
  border-bottom: 1px solid var(--color-nav-border);
  border-top: 1px solid var(--color-nav-border);

  ul {
    background: var(--color-surface);
    overflow-y: auto;
    margin: 0;
    width: 16.5em;
    max-height: 25em;
    transition: max-height 0.4s;

    li {
      font-size: smaller;
      width: 100%;
      transition: background 0.4s;

      &:nth-child(even) {
        background: var(--color-surface-sunken);
      }

      &.added-word {
        background: var(--color-success);
        display: none;
      }

      .length {
        opacity: 0.5;
        font-size: smaller;
        text-align: center;
      }
    }
  }
}

// Potential word row — replaces inline style="margin: 0 auto"
.potential-word__row {
  margin: 0 auto;
}

// --- Toggle switches ---

$switch-height: 1.8em;
$switch-width: 4em;
$pip-diameter: $switch-width/3;
$switch-on-color: var(--color-accent);
$switch-off-color: var(--color-border);
.switch-form {
  display: inline-block;
  margin: 0;
  height: $switch-height;
  position: relative;
  .switch {
    position: relative;
    width: $switch-width;
    background: white;
    height: $switch-height;
    display: inline-block;
    border-width: 1px;
    border-style: solid;
    border-radius: $pip-diameter;
    transition: all 0.2s;
  }
  .pip {
    position: absolute;
    display: inline-block;
    height: $pip-diameter;
    width: $pip-diameter;
    margin-top: $switch-height/14;
    border-radius: $pip-diameter/2;
    transition: all 0.2s;
  }
  label {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5em;
    width: auto;
    white-space: nowrap;
    &.on {
      .switch {
        border-color: $switch-on-color;
      }
      .pip {
        left: $switch-width*3/5;
        background: $switch-on-color;
      }
    }
    &.off {
      .switch {
        border-color: $switch-off-color;
      }
      .pip {
        left: $switch-width/15;
        background: $switch-off-color;
      }
    }
  }
  span {
    height: 1em;
    position: static;
  }
  // Visually hidden but still focusable — enables keyboard Tab + Space/Enter toggling.
  // display:none would remove the checkbox from tab order entirely.
  input[type=checkbox] {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  // Visual feedback when checkbox receives keyboard focus.
  // .switch is before checkbox in DOM, so use :has() to target the ancestor label.
  label:has(input[type=checkbox]:focus-visible) .switch {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
}

@media (max-height: 700px){
  #ideas ul, #word-match-results {
    max-height: 15em;
  }
}

// --- Tablet: wider tool panels ---
@media (max-width: #{$bp-lg - 1}) and (min-width: $bp-sm) {
  .slide-up-container {
    &#pattern-container { width: 24em; }
  }
  #pattern-search, #ideas, #ideas ul { width: 100%; }
}

// --- Phone: full-width tool panels + tighter switches ---
@media (max-width: #{$bp-sm - 1}) {
  .slide-up-container {
    &#pattern-container,
    &#idea-container {
      left: 0;
      right: 0;
      width: 100%;
    }
    // Phone: open to 60% so puzzle stays partially visible above
    &.open {
      top: 60%;
    }
  }
  #pattern-search,
  #ideas {
    width: 100%;
  }
  #ideas ul {
    width: 100%;
  }

  // Prevent switch labels from being clipped on narrow screens
  .xw-edit-switches {
    gap: 0.5em 1em;
  }
  .switch-form label {
    font-size: var(--text-sm);
  }
}
