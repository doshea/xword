// =============================================================================
// Welcome Landing Page — Chalkboard on Café
// =============================================================================
// Standalone page: cozy café photo background + chalkboard widget with
// signup/login slider. All values use design tokens. BEM: .xw-chalkboard.
// =============================================================================

@import 'design_tokens';

// ---------------------------------------------------------------------------
// Page shell — full-viewport café background
// ---------------------------------------------------------------------------

html {
  background-color: var(--color-bg);
  background: url("<%= asset_path 'welcome/couch_cafe.jpg' %>") no-repeat center center var(--color-bg);
  background-size: cover;
  height: 100%;
}

body {
  height: 100%;
}

#body {
  margin: 0;
  padding: 0;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

footer#footer {
  margin: 0;
}


// ---------------------------------------------------------------------------
// Chalkboard container
// ---------------------------------------------------------------------------

.xw-chalkboard {
  background: url("<%= asset_path 'welcome/chalkboard_black.png' %>") no-repeat;
  width: 23.3em;
  height: 29.5em;
  box-shadow: var(--shadow-chalkboard);
  color: var(--color-nav-text);
  text-align: center;
  position: relative;
  overflow: hidden;
  font-family: var(--font-body);
}


// ---------------------------------------------------------------------------
// Slider — two panels side by side, CSS transition on transform
// ---------------------------------------------------------------------------

.xw-chalkboard__slider {
  display: flex;
  width: 200%;
  height: 100%;
  transition: transform var(--duration-slow) var(--ease-in-out);
}

.xw-chalkboard--login-active .xw-chalkboard__slider {
  transform: translateX(-50%);
}


// ---------------------------------------------------------------------------
// Panels
// ---------------------------------------------------------------------------

.xw-chalkboard__panel {
  width: 50%;
  height: 100%;
  padding: var(--space-8) var(--space-6) var(--space-4);
  display: flex;
  flex-direction: column;
  align-items: center;
}


// ---------------------------------------------------------------------------
// Welcome board image (signup panel header)
// ---------------------------------------------------------------------------

.xw-chalkboard__welcome {
  margin-bottom: var(--space-3);
}

.xw-chalkboard__welcome-img {
  height: 4em;
  width: auto;
}


// ---------------------------------------------------------------------------
// Login panel heading
// ---------------------------------------------------------------------------

.xw-chalkboard__heading {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: var(--weight-semibold);
  color: var(--color-text-inverse);
  margin: 0 0 var(--space-4);
  letter-spacing: var(--tracking-tight);
}


// ---------------------------------------------------------------------------
// Form elements — chalk aesthetic
// ---------------------------------------------------------------------------

.xw-chalkboard__form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.xw-chalkboard__field {
  width: 65%;
  margin-bottom: var(--space-1);
}

.xw-chalkboard__input {
  width: 100%;
  border: none;
  border-bottom: 1px dotted var(--color-nav-text-dim);
  color: var(--color-text-inverse);
  background: none;
  text-align: center;
  font-size: inherit;
  font-family: inherit;
  padding: var(--space-1) 0;
  box-shadow: none;

  &:focus {
    outline: none;
    border-bottom-color: var(--color-text-inverse);
  }

  &::placeholder {
    color: var(--color-nav-text-dim);
  }
}


// ---------------------------------------------------------------------------
// Buttons
// ---------------------------------------------------------------------------

.xw-chalkboard__btn {
  margin: var(--space-3) auto 0;
  padding: var(--space-2) 0;
  color: var(--color-text-inverse);
  border: 1px outset var(--color-nav-text-dim);
  display: block;
  text-align: center;
  width: 10em;
  background: rgba(255, 255, 255, 0.15);
  font-size: inherit;
  font-family: inherit;
  cursor: pointer;
  position: relative;
  transition: background-color var(--duration-base) var(--ease-in-out);

  &:hover {
    background: var(--color-nav-border);
  }

  .xw-icon {
    vertical-align: middle;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);

    &.xw-icon--arrow-left  { left: var(--space-3); }
    &.xw-icon--arrow-right { right: var(--space-3); }
  }
}


// ---------------------------------------------------------------------------
// Misc elements
// ---------------------------------------------------------------------------

.xw-chalkboard__or {
  display: block;
  margin-top: var(--space-2);
  color: var(--color-nav-text-dim);
  font-size: var(--text-sm);
}

.xw-chalkboard__remember {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  margin: var(--space-2) 0 var(--space-3);
}

.xw-chalkboard__remember-label {
  color: var(--color-nav-text-dim);
  font-size: var(--text-sm);
  cursor: pointer;
}

.xw-chalkboard__checkbox {
  cursor: pointer;
}

.xw-chalkboard__forgot {
  display: inline-block;
  margin-top: var(--space-4);
  color: var(--color-nav-text-dim);
  font-size: var(--text-sm);
  text-decoration: underline;
  text-underline-offset: 2px;

  &:hover {
    color: var(--color-nav-text);
  }
}


// ---------------------------------------------------------------------------
// Form error summary (on dark chalkboard background)
// ---------------------------------------------------------------------------

.xw-chalkboard .xw-alert--error {
  background: rgba(184, 64, 64, 0.3);
  border: 1px solid var(--color-danger);
  color: var(--color-text-inverse);
  font-size: var(--text-sm);
  padding: var(--space-2);
  margin-bottom: var(--space-2);
  border-radius: var(--radius-sm);
  width: 80%;

  ul { padding-left: var(--space-4); }
  li { font-size: var(--text-xs); }
}


// ---------------------------------------------------------------------------
// Browse bypass link (below chalkboard)
// ---------------------------------------------------------------------------

.xw-welcome-bypass {
  text-align: center;
  margin-top: var(--space-4);
}

.xw-welcome-bypass__link {
  color: var(--color-text-inverse);
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  text-decoration: none;
  opacity: 0.7;
  transition: opacity var(--duration-base) var(--ease-in-out);

  &:hover {
    opacity: 1;
  }

  .xw-icon {
    vertical-align: middle;
    margin-left: var(--space-1);
  }
}


// ---------------------------------------------------------------------------
// Mobile — dark container, no chalkboard image, show/hide panels
// ---------------------------------------------------------------------------

@media (max-width: #{$bp-sm - 1}px) {
  .xw-chalkboard {
    width: calc(100vw - var(--space-8));
    max-width: 24em;
    height: auto;
    background-image: none;
    background-color: var(--color-nav-bg);
    border-radius: var(--radius-lg);
    margin: var(--space-6) auto;
    padding: var(--space-2);
  }

  .xw-chalkboard__slider {
    display: block;
    width: 100%;
    transition: none;
    transform: none !important;
  }

  .xw-chalkboard__panel {
    width: 100%;
    height: auto;
    padding: var(--space-4) var(--space-2);
  }

  // On mobile, hide/show panels instead of sliding
  .xw-chalkboard__panel--login {
    display: none;
  }

  .xw-chalkboard--login-active {
    .xw-chalkboard__panel--signup { display: none; }
    .xw-chalkboard__panel--login  { display: flex; }
  }

  .xw-chalkboard__field {
    width: 85%;
  }
}


// ---------------------------------------------------------------------------
// Reduced motion
// ---------------------------------------------------------------------------

@media (prefers-reduced-motion: reduce) {
  .xw-chalkboard__slider {
    transition: none;
  }
}
