// Minimal CSS reset — replaces normalize.css (removed with Foundation 5 in Phase 6)
*,
*::before,
*::after  { box-sizing: border-box; }
body      { margin: 0; font-family: var(--font-body); color: var(--color-text); }
img, svg  { display: block; max-width: 100%; }
button,
input,
select,
textarea  { font: inherit; }

h1, h2, h3, h4, h5, h6 { font-family: var(--font-display); }

// Focus rings: visible for keyboard users, hidden for mouse/touch
:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}
// Suppress outlines only where JS manages focus
.no-select *,
table#crossword td {
  outline: none;
}
.xw-thumbnail {
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border);
}
.xw-icon--favorited { fill: var(--color-accent); color: var(--color-accent); }
.xw-icon--danger { color: var(--color-danger); }
.xw-icon--accent { color: var(--color-accent); }
.borderless {
  border: none !important;
}
.relative {
  position: relative;
}
.hidden {
  display: none;
}
.ib {
  display: inline-block;
}
.no-margin {
  margin: 0;
}
ul {
  list-style-type: none;
  .bulleted {
    list-style-type: disc;
  }
}
html {
  background: url(<%= asset_path('wood_table.jpg') %>) no-repeat center center fixed;
  background-size: cover;
  height: 100%;
}
body {
  background: none;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
#body {
  margin-top: 1em;
  flex: 1 0 auto;
  & > .xw-container {
    background-color: var(--color-surface);
  }
  & > .row-bookend {
    min-height: 1.5em;
    background: var(--color-nav-bg);
    text-align: center;
    p, h1, h2, h3, h4, h5, h6 {
      color: var(--color-nav-text);
      margin: 0; // Prevent margin collapsing through the bookend (no padding/border to contain it)
    }
  }
  & > .row-topper {
    border-radius: 1em 1em 0 0;
    margin-top: 2em;
    padding: var(--space-3) var(--space-4);
    h1 { font-size: 1.4375rem; } // preserve h4 visual size (Foundation 5 h4 = rem-calc(23))
  }
  & > .row-stopper {
    border-radius: 0 0 1em 1em;
  }
}

.no-select {
  &::selection,
  * ::selection {
    background-color: transparent;
  }
}

.smaller {
  font-size: smaller;
}
.larger {
  font-size: larger;
}
.center {
  text-align: center;
}
.text-left {
  text-align: left;
}
.text-right {
  text-align: right;
}

// Auth page two-column layout (login + signup side by side)
.xw-auth-layout {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rem;
  padding: 1rem 0;
}
.xw-auth-column {
  flex: 0 1 22rem;
  min-width: 15rem;
}

// Error page centered image
.xw-error-image {
  display: block;
  margin: 0 auto;
  width: 75%;
}

// Error/auth page centered icon — large muted icon above heading
.xw-error-icon {
  text-align: center;
  margin-bottom: var(--space-4);
  color: var(--color-text-muted);

  svg { display: inline-block; }
}


// Form error summary (shared partial)
.form-error-summary {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-danger-text);
  margin-bottom: var(--space-2);
}

// Admin utility classes — moved to admin.scss

// Turbo Drive progress bar — shows during page navigation
.turbo-progress-bar {
  height: 3px;
  background-color: var(--color-accent);
}

// Pure CSS spinner for loading states
.xw-spinner {
  display: inline-block;
  width: 1em;
  height: 1em;
  border: 2px solid var(--color-border);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: xw-spin 0.6s linear infinite;
  vertical-align: middle;
}
@keyframes xw-spin { to { transform: rotate(360deg); } }

// Cross-browser scrollbar styling
// Standard properties (Firefox, Chrome 121+)
* {
  scrollbar-width: thin;
  scrollbar-color: var(--color-scrollbar-thumb) transparent;
}
// WebKit fallback (older Chrome/Safari)
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-thumb {
  border-radius: 8px;
  border: 2px solid var(--color-surface);
  background-color: var(--color-scrollbar-thumb);
}
