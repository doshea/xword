// Minimal CSS reset — replaces normalize.css (removed with Foundation 5 in Phase 6)
*,
*::before,
*::after  { box-sizing: border-box; }
body      { margin: 0; font-family: var(--font-body); color: var(--color-text); }
img, svg  { display: block; max-width: 100%; }
button,
input,
select,
textarea  { font: inherit; }

h1, h2, h3, h4, h5, h6 { font-family: var(--font-display); }
hr {
  border: none;
  border-top: 1px solid var(--color-border);
  margin: var(--space-4) 0;
}

// Focus rings: visible for keyboard users, hidden for mouse/touch
:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}
// Suppress outlines only where JS manages focus
.no-select *,
table#crossword td {
  outline: none;
}
.xw-thumbnail {
  max-width: 100%;
  height: auto;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border);
}
.xw-icon--favorited { fill: var(--color-accent); color: var(--color-accent); }
.xw-icon--danger { color: var(--color-danger); }
.xw-icon--accent { color: var(--color-accent); }
.borderless {
  border: none !important;
}
.relative {
  position: relative;
}
.hidden {
  display: none;
}
.ib {
  display: inline-block;
}
.no-margin {
  margin: 0;
}
ul {
  list-style-type: none;
  .bulleted {
    list-style-type: disc;
  }
}
html {
  background: url(<%= asset_path('wood_table.jpg') %>) no-repeat center center fixed;
  background-size: cover;
  height: 100%;
}
body {
  background: none;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
#body {
  margin-top: 1em;
  flex: 1 0 auto;
  & > .xw-container {
    background-color: var(--color-surface);
  }
  & > .row-bookend {
    min-height: 1.5em;
    background: var(--color-nav-bg);
    text-align: center;
    p, h1, h2, h3, h4, h5, h6 {
      color: var(--color-nav-text);
      margin: 0; // Prevent margin collapsing through the bookend (no padding/border to contain it)
    }
  }
  & > .row-topper {
    border-radius: 1em 1em 0 0;
    margin-top: 2em;
    padding: var(--space-3) var(--space-4);
    h1 { font-size: var(--text-2xl); }
  }
  & > .row-stopper {
    border-radius: 0 0 1em 1em;
  }
}

.no-select {
  &::selection,
  * ::selection {
    background-color: transparent;
  }
}

.smaller {
  font-size: smaller;
}
.larger {
  font-size: larger;
}
.center {
  text-align: center;
}
.text-left {
  text-align: left;
}
.text-right {
  text-align: right;
}

// Auth page two-column layout (login + signup side by side)
.xw-auth-layout {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rem;
  padding: 1rem 0;
}
.xw-auth-column {
  flex: 0 1 22rem;
  min-width: 15rem;
}

// Error page centered image
.xw-error-image {
  display: block;
  margin: 0 auto;
  width: 75%;
}

// Error/auth page centered icon — large muted icon above heading
.xw-error-icon {
  text-align: center;
  margin-bottom: var(--space-4);
  color: var(--color-text-muted);

  svg { display: inline-block; }
}


// Form error summary (shared partial)
.form-error-summary {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-danger-text);
  margin-bottom: var(--space-2);
}

// Admin utility classes — moved to admin.scss

// Turbo Drive progress bar — shows during page navigation
.turbo-progress-bar {
  height: 3px;
  background-color: var(--color-accent);
}

// Pure CSS spinner for loading states
.xw-spinner {
  display: inline-block;
  width: 1em;
  height: 1em;
  border: 2px solid var(--color-border);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: xw-spin 0.6s linear infinite;
  vertical-align: middle;
}
@keyframes xw-spin { to { transform: rotate(360deg); } }

// Lazy-load placeholder — centered spinner + text for deferred tab content
.xw-loading-placeholder {
  padding: var(--space-8) var(--space-4);
  text-align: center;
  color: var(--color-text-secondary);

  .xw-spinner {
    display: block;
    margin: 0 auto var(--space-3);
    width: 1.5em;
    height: 1.5em;
  }
}

// Clicked-element loading state — applied during Turbo Drive page navigations
.xw-loading {
  opacity: 0.5;
  pointer-events: none;
  transition: opacity var(--duration-fast) var(--ease-out);
}

// Puzzle cards get a centered spinner overlay when their parent <a> is loading
a.xw-loading > .xw-puzzle-card {
  position: relative;

  &::after {
    content: '';
    position: absolute;
    top: calc(50% - 0.75em);
    left: calc(50% - 0.75em);
    width: 1.5em;
    height: 1.5em;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    animation: xw-spin 0.6s linear infinite;
  }
}

@media (prefers-reduced-motion: reduce) {
  .xw-loading { transition: none; }
  a.xw-loading > .xw-puzzle-card::after { animation: none; }
}

// Cross-browser scrollbar styling
// Standard properties (Firefox, Chrome 121+)
* {
  scrollbar-width: thin;
  scrollbar-color: var(--color-scrollbar-thumb) transparent;
}
// WebKit fallback (older Chrome/Safari)
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-thumb {
  border-radius: 8px;
  border: 2px solid var(--color-surface);
  background-color: var(--color-scrollbar-thumb);
}

// ---------------------------------------------------------------------------
// MINI-MANUAL — shared by solve "How to Solve" and edit "How to Edit" modals
// ---------------------------------------------------------------------------

// Keycap styling for <kbd> elements (keyboard shortcuts)
kbd {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  padding: 2px 6px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-surface-alt);
  box-shadow: 0 1px 0 var(--color-border-strong);
  min-width: 1.6em;
  text-align: center;
  white-space: nowrap;
}

.xw-manual {
  max-height: 70vh;
  overflow-y: auto;

  &__heading {
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-6);
  }

  &__section {
    margin-bottom: var(--space-6);

    h3 {
      font-family: var(--font-display);
      font-size: var(--text-base);
      margin: 0 0 var(--space-2);
      color: var(--color-text);
    }
  }

  &__table {
    width: 100%;
    border-collapse: collapse;

    td {
      padding: var(--space-2) var(--space-3);
      font-family: var(--font-body);
      font-size: var(--text-sm);
      vertical-align: middle;
      border-bottom: 1px solid var(--color-border);
    }

    tr:last-child td {
      border-bottom: none;
    }

    // Action column (left)
    td:first-child {
      font-weight: 500;
      color: var(--color-text);
      white-space: nowrap;
      width: 40%;
    }

    // How/detail column (right)
    td:last-child {
      color: var(--color-text-secondary);
    }
  }

  &__text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  &__note {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
    margin: var(--space-2) 0 0;
  }

  &__keys {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  &__arrow-keys {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  &__arrow-row {
    display: flex;
    gap: 2px;
  }

  &__key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    font-size: var(--text-sm);
    border-radius: 4px;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-body);
    line-height: 1;
  }

  &__key-hints {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.8;
  }
}

// 639px = $bp-sm - 1 (global.scss.erb doesn't @import _design_tokens)
@media (max-width: 639px) {
  .xw-manual {
    max-height: 80vh;

    &__table td {
      padding: var(--space-1) var(--space-2);
      font-size: var(--text-xs);
    }

    &__table td:first-child {
      white-space: normal;
    }
  }
}
