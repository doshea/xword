// Minimal CSS reset — replaces normalize.css (removed with Foundation 5 in Phase 6)
*,
*::before,
*::after  { box-sizing: border-box; }
body      { margin: 0; font-family: var(--font-body); color: var(--color-text); }
img, svg  { display: block; max-width: 100%; }
button,
input,
select,
textarea  { font: inherit; }

h1, h2, h3, h4, h5, h6 { font-family: var(--font-display); }

// Focus rings: visible for keyboard users, hidden for mouse/touch
:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}
// Suppress outlines only where JS manages focus
.no-select *,
table#crossword td {
  outline: none;
}
.dark-shadow {
  box-shadow: 3px 3px 3px black;
}
.xw-thumbnail {
  box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
  border: 1px solid var(--color-border);
}
.xw-icon--favorited { color: #ff7878; }
.xw-icon--danger { color: var(--color-danger); }
.xw-icon--accent { color: var(--color-accent); }
.borderless {
  border: none !important;
}
.relative {
  position: relative;
}
.hidden {
  display: none;
}
.ib {
  display: inline-block;
}
.no-margin {
  margin: 0;
}
ul {
  list-style-type: none;
  .bulleted {
    list-style-type: disc;
  }
}
html {
  background: url(<%= asset_path('wood_table.jpg') %>) no-repeat center center fixed;
  background-size: cover;
  height: 100%;
}
body {
  background: none;
  min-height: 100%;
  height: 100%;
}
#body {
  margin-top: 1em;
  min-height: 92%;
  & > .xw-container {
    background-color: var(--color-surface);
  }
  & > .row-bookend {
    min-height: 1.5em;
    background: var(--color-nav-bg);
    text-align: center;
    p, h1, h2, h3, h4, h5, h6 {
      color: var(--color-nav-text);
    }
  }
  & > .row-topper {
    border-radius: 1em 1em 0 0;
    margin-top: 2em;
    h1 { font-size: 1.4375rem; } // preserve h4 visual size (Foundation 5 h4 = rem-calc(23))
  }
  & > .row-stopper {
    border-radius: 0 0 1em 1em;
  }
}

.no-select {
  &::selection,
  * ::selection {
    background-color: transparent;
  }
}

.smaller {
  font-size: smaller;
}
.larger {
  font-size: larger;
}
.center {
  text-align: center;
}
.text-left {
  text-align: left;
}
.text-right {
  text-align: right;
}

// Auth page two-column layout (login + signup side by side)
.xw-auth-layout {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rem;
  padding: 1rem 0;
}
.xw-auth-column {
  flex: 0 1 22rem;
  min-width: 15rem;
}

// Error page centered image
.xw-error-image {
  display: block;
  margin: 0 auto;
  width: 75%;
}

// Foundation typography survival shims (ensure Phase 6 doesn't regress)
.lead  { font-size: 1.21875rem; line-height: var(--leading-relaxed); }
.subheader { color: var(--color-text-muted); font-weight: var(--weight-normal); }
