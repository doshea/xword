@import 'dimensions';

#body > .xw-container {
  padding: 0.5em 1em 0 1em;
  max-width: $row-width+2em;
}

#credit-area, #solve-area, #meta-area, #advanced {
  background-image: url("<%= asset_path 'paper.jpeg' %>");
}

#credit-area {
  margin-top: 2.5em;
  margin-bottom: 0;
  border-top-left-radius: 0.3em;
  border-top-right-radius: 0.3em;
  h1 {
    margin-bottom: 0.2em;
    #creator-credit {
      font-size: large;
      font-weight: normal;
    }
  }
  #puzzle-controls {
    position: absolute;
    right: 0.5em;
    top: 0.5em;
    .secondary {
      border: 1px solid #ccc;
    }
  }
}
#meta-area {
  border-bottom-left-radius: 0.3em;
  border-bottom-right-radius: 0.3em;
}

table#crossword {
  border-spacing: 0;
  float: left;
  margin-bottom: 0;

  tr {
    background: black;
  }
  .cell {
    padding: 0;
    margin: 0;
    border: solid 0.0625em var(--color-cell-border);
    font-size: 1.25em;
    text-align: center;
    text-transform: uppercase;
    width: 1.5em;
    height: 1.5em;
    position: relative;
    background: var(--color-cell-bg);
    overflow: hidden;

    &.void {
      background-color: var(--color-cell-void) !important;
    }
    &:not(.void){
      cursor: text;
    }
    &.selected{
      background-color: var(--color-cell-selected);
    }
    &.selected-word:not(.selected) {
      background-color: var(--color-cell-word);
    }
    .letter {
      line-height: 145%;
      z-index: 1001;
    }
    .cell-num {
      position: absolute;
      top: 0;
      left: 1px;
      font-size: 0.4em;
      line-height: 1em;
    }
    .flag {
      display: none;
      position: absolute;
      width: 0;
      height: 0;
      top: 0;
      right: 1px;
      z-index: 1000;
      border-style: solid;
      border-width: 0 0.35em 0.35em 0;
    }

    .circle {
      height: 100%;
      width: 100%;
      position: absolute;
      border: 1px solid var(--color-cell-border);
      border-radius: 50%;
      top: 0;
    }
  }
}
.flagged .flag  {
  display: block !important;
}
.incorrect .flag {
  border-color: transparent var(--color-danger) transparent transparent;
}
.correct .flag {
  border-color: transparent var(--color-success) transparent transparent;
}

.xw-puzzle-layout {
  display: flex;
  align-items: flex-start;
  gap: 0.5em;

  .clue-column {
    flex: 1;
    min-width: 0;
    margin-left: 0;
  }

  .clues {
    width: 100%;
  }
}

.clue-column {
  float: left;
  background: var(--color-surface-alt);
  border: 1px solid var(--color-border);
  margin-left: 0.4em;
  margin-right: 0;
  h3 {
    text-align: center;
  }
  .clues {
    overflow: auto;
    width: 250px;
    overflow-x: hidden;
    background: var(--color-surface);
    font-size: smaller;
    padding: 0.1em 0.25em;
    height: 31em;

    .clue {
      border: 1px solid rgba(255,255,255,0);
      border-bottom: 1px solid var(--color-border);
      padding: 0 0.25em 0 2em;
      text-indent: -1.7em;
      cursor: pointer;

      &.crossed-off {
        text-decoration: line-through;
        opacity: 0.5;
      }

      &.selected-clue {
        background-color: var(--color-cell-word);
        border: 1px solid #999;
      }
    }
    input {
      height: 1.5em;
      display: inline-block;
      border: none;
      box-shadow: none;
      background: none;
      margin-bottom: 0;
      cursor: pointer;
      &:focus {
        cursor: text;
      }
    }
  }
}


#solve-controls {
  position: relative;
  margin-left: 0.6em;
  margin: 0.2em;
  float: left;
  width: 32em;
  padding: 0;
  text-align: center;
  button {
    display: inline-block;
    height: inherit;
    width: 49%;
    margin: 0;
    outline: none;
  }
  hr {
    margin: 0.2em 0;
  }
}

#preview {
  text-align: center;
  canvas {
    display: inline-block;
  }
}
#teammates {
  display: inline-block;
  .teammate-box {
    width: 1em;
    height: 1em;
    box-shadow: 1px 1px 2px #444;
    display: inline-block;
    margin-right: 0.2em;
  }
}

#team-chat {
  width: 300px;
  position: fixed;
  background: var(--color-surface);
  right: 2em;
  border: 1px solid black;
  border-bottom: none;
  border-top-left-radius: 0.5em;
  border-top-right-radius: 0.5em;
  transition: bottom 0.2s;
  z-index: 1;
  box-shadow: rgba(0, 0, 0, 0.5) 0px 0px 15px;

  &.down {
    bottom: -2.7em;
  }
  &:not(.down) {
    bottom: 0 !important;
  }
  form {
    margin: 0;
    height: 2.5em;
  }

  .row-topper {
    height: 1.5em;
    background: black;
    border-top-left-radius: 0.5em;
    border-top-right-radius: 0.5em;
    color: white;
    text-align: center;
    font-weight: bold;
    padding-top: 0.2em;
    cursor: pointer;

    #chat-minmax {
      position: absolute;
      right: 1em;
    }
  }
  input {
    position: absolute;
    padding: 0 0.5em;
    height: 2em;
    bottom: 0.5em;
    margin: 0;
    width: 96%;
    left: 2%;
    right: 2%;
  }
  #chats {
    overflow: auto;
    max-height: 330px;
    padding: 0.1em;

    hr {
      margin: 0;
    }
  }
  .chat {
    padding: 0.2em 0.6em 0.2em 0.4em;
    width: 100%;
    font-size: 0.8em;
    min-height: 1.6em;
    transition: all 0.5s linear;
    img {
      height: 1.2em;
      width: 1.2em;
    }
    &.my-chat {
      text-align: right;
      background-color: #eee;
    }
    .avatar {
      width: 1.2em;
      height: 1.2em;
    }
    .display-name {
      font-weight: bold;
      margin-left: 0.2em;
    }
    .chat-text {
      max-width: 100%;
      overflow-wrap: break-word;
    }
    span {
      vertical-align: bottom;
    }
  }
}
#comments {
  textarea {
    resize: none;
    overflow: auto;
  }
  .comment {
    li {
      width: 70%;
    }
    textarea {
      height: 1em;
      min-height: 2.3em;
    }
  }
}
.team-outline {
  position: absolute;
  z-index: 999;
}

#controls-modal {
  width: 40%;
  margin-left: -20%;
  min-width: 25em;
  h1 {
    text-align: center;
  }
  li {
    font-size: 0.875em;
  }

  #keys {
    list-style-type: none;
    li {
      text-align: right;
    }
  }
}
