@import 'dimensions';

#body > .xw-container {
  padding-inline: 1em;
  max-width: $row-width+2em;
}

#credit-area, #solve-area, #meta-area, #advanced {
  background-image: url("<%= asset_path 'paper.jpeg' %>");
  padding-top: var(--space-4);
  padding-bottom: var(--space-4);
}

#credit-area {
  margin-top: 2.5em;
  margin-bottom: 0;
  padding-top: var(--space-6);
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  box-shadow: var(--shadow-paper);
  .xw-col-full {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }
  h1 {
    margin-bottom: 0;
    #creator-credit {
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: var(--weight-normal);
      color: var(--color-text-secondary);
      margin-left: var(--space-2);
    }
  }
  #puzzle-controls {
    position: static;
    display: flex;
    align-items: center;
    gap: 0.5em;
    flex-wrap: wrap;

    .smaller {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }
  }
}
#meta-area {
  border-bottom-left-radius: var(--radius-lg);
  border-bottom-right-radius: var(--radius-lg);

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-4) 0;
  }
}

table#crossword {
  border-spacing: 0;
  float: left;
  margin-bottom: 0;

  tr {
    background: black;
  }
  .cell {
    padding: 0;
    margin: 0;
    border: solid 0.0625em var(--color-cell-border);
    font-size: 1.25em;
    text-align: center;
    text-transform: uppercase;
    width: 1.5em;
    height: 1.5em;
    position: relative;
    background: var(--color-cell-bg);
    overflow: hidden;

    &.void {
      background-color: var(--color-cell-void) !important;
    }
    &:not(.void){
      cursor: text;
    }
    &.selected{
      background-color: var(--color-cell-selected);
    }
    &.selected-word:not(.selected) {
      background-color: var(--color-cell-word);
    }
    .letter {
      line-height: 145%;
      z-index: 1001;
    }
    .cell-num {
      position: absolute;
      top: 0;
      left: 1px;
      font-size: 0.4em;
      line-height: 1em;
    }
    .flag {
      display: none;
      position: absolute;
      width: 0;
      height: 0;
      top: 0;
      right: 1px;
      z-index: 1000;
      border-style: solid;
      border-width: 0 0.35em 0.35em 0;
    }

    .circle {
      height: 100%;
      width: 100%;
      position: absolute;
      border: 1px solid var(--color-cell-border);
      border-radius: 50%;
      top: 0;
    }
  }
}
.flagged .flag  {
  display: block !important;
}
.incorrect .flag {
  border-color: transparent var(--color-danger) transparent transparent;
}
.correct .flag {
  border-color: transparent var(--color-success) transparent transparent;
}

.xw-puzzle-layout {
  display: flex;
  align-items: flex-start;
  gap: 0.5em;

  .clue-column {
    flex: 1;
    min-width: 0;
    margin-left: 0;

    .clues {
      width: 100%;
    }
  }
}

.clue-column {
  float: left;
  background: transparent;
  border: none;
  border-left: none;
  margin-left: 0.75em;
  margin-right: 0;
  h3 {
    text-align: center;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
    margin: var(--space-2) var(--space-3) var(--space-3);
  }
  .clues {
    position: relative;
    overflow: auto;
    width: 250px;
    overflow-x: hidden;
    background: var(--color-surface-alt);
    box-shadow: var(--shadow-inner);
    border-radius: var(--radius-sm);
    font-size: smaller;
    padding: var(--space-1) var(--space-2);
    height: 31em;

    .clue {
      border: 1px solid rgba(255,255,255,0);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-1) 0.25em var(--space-1) 2em;
      text-indent: -1.7em;
      cursor: pointer;

      &.crossed-off {
        text-decoration: line-through;
        opacity: 0.5;
      }

      &.selected-clue {
        background-color: var(--color-cell-word);
        border: 1px solid #999;
      }
    }
    .clue-num {
      color: var(--color-text-muted);
    }
    input {
      height: 1.5em;
      display: inline-block;
      border: none;
      box-shadow: none;
      background: none;
      margin-bottom: 0;
      cursor: pointer;
      &:focus {
        cursor: text;
      }
    }
  }
}


#solve-controls {
  margin-bottom: var(--space-2);
}

#preview {
  text-align: center;
  canvas {
    display: inline-block;
  }
}
#teammates {
  display: inline-block;
  .teammate-box {
    width: 1em;
    height: 1em;
    box-shadow: 1px 1px 2px #444;
    display: inline-block;
    margin-right: 0.2em;
  }
}

#team-chat {
  width: 300px;
  position: fixed;
  background: var(--color-surface);
  right: 2em;
  border: 1px solid black;
  border-bottom: none;
  border-top-left-radius: 0.5em;
  border-top-right-radius: 0.5em;
  transition: bottom 0.2s;
  z-index: 1;
  box-shadow: rgba(0, 0, 0, 0.5) 0px 0px 15px;

  &.down {
    bottom: -2.7em;
  }
  &:not(.down) {
    bottom: 0 !important;
  }
  form {
    margin: 0;
    height: 2.5em;
  }

  .row-topper {
    height: 1.5em;
    background: black;
    border-top-left-radius: 0.5em;
    border-top-right-radius: 0.5em;
    color: white;
    text-align: center;
    font-weight: bold;
    padding-top: 0.2em;
    cursor: pointer;

    #chat-minmax {
      position: absolute;
      right: 1em;
    }
  }
  input {
    position: absolute;
    padding: 0 0.5em;
    height: 2em;
    bottom: 0.5em;
    margin: 0;
    width: 96%;
    left: 2%;
    right: 2%;
  }
  #chats {
    overflow: auto;
    max-height: 330px;
    padding: 0.1em;

    hr {
      margin: 0;
    }
  }
  .chat {
    padding: 0.2em 0.6em 0.2em 0.4em;
    width: 100%;
    font-size: 0.8em;
    min-height: 1.6em;
    transition: all 0.5s linear;
    img {
      height: 1.2em;
      width: 1.2em;
    }
    &.my-chat {
      text-align: right;
      background-color: #eee;
    }
    .avatar {
      width: 1.2em;
      height: 1.2em;
    }
    .display-name {
      font-weight: bold;
      margin-left: 0.2em;
    }
    .chat-text {
      max-width: 100%;
      overflow-wrap: break-word;
    }
    span {
      vertical-align: bottom;
    }
  }
}
#comments {
  h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  textarea {
    background-color: var(--color-surface-sunken);
    border-color: transparent;
    resize: none;
    overflow: auto;
  }
}

// --- Comment & reply layout ---

.xw-comment {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-3) 0;

  &__avatar {
    flex-shrink: 0;
    img { border-radius: 50%; }
  }
  &__body {
    flex: 1;
    min-width: 0;

    li {
      width: 70%;
    }
    textarea {
      height: 1em;
      min-height: 2.3em;
    }
  }
  &__reply-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
    cursor: pointer;
  }
}

.xw-reply {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-2) 0;
  margin-left: var(--space-6);

  &__avatar {
    flex-shrink: 0;
    img { border-radius: 50%; }
  }
  &__body {
    flex: 1;
    min-width: 0;
  }
}

// Initial display states for reply toggle (jQuery toggle_reply_form manages visibility)
.cancel-button { display: none; }
.reply-form { display: none; }

.reply-button {
  display: inline-flex;
  align-items: center;
  gap: 0.25em;
  cursor: pointer;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  &:hover { color: var(--color-text); }
}

.reply-controls {
  display: flex;
  gap: var(--space-2);
  margin-top: var(--space-1);
  a {
    color: var(--color-text-muted);
    cursor: pointer;
    &:hover { color: var(--color-text); }
  }
}
.team-outline {
  position: absolute;
  z-index: 999;
}

// --- Controls modal ---

#controls-modal {
  max-width: 28rem;

  .controls-modal__heading {
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
  }
  .controls-modal__columns {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
  }
  .controls-modal__actions {
    list-style: none;
    padding: 0;
    li {
      font-family: var(--font-ui);
      font-size: var(--text-sm);
      padding: var(--space-1) 0;
      color: var(--color-text-secondary);
    }
  }
  .controls-modal__keys {
    list-style: none;
    padding: 0;
    text-align: right;
    li { padding: var(--space-1) 0; }
  }
  kbd {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.15em 0.5em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-sunken);
    box-shadow: 0 1px 0 var(--color-border-strong);
    min-width: 2em;
    text-align: center;
  }
  .controls-modal__arrow-key {
    min-width: 1.5em;
    padding: 0.15em 0.3em;
  }
}

// --- Win modal ---

#win-modal {
  text-align: center;

  .win-modal__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .win-modal__congrats {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }
  .win-modal__subtitle {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }
  .win-modal__time {
    margin-bottom: var(--space-4);
  }
  .win-clock {
    display: inline-block;
    background: var(--color-nav-bg);
    color: var(--color-surface);
    padding: 2px var(--space-2) 0;
    border-radius: var(--radius-sm);
  }
  .win-clock__segment {
    display: inline-block;
  }
  .win-clock__separator {
    vertical-align: top;
    line-height: 37px;
  }
  .win-clock__ms-dot {
    position: relative;
    bottom: 7px;
  }
  .win-modal__prompt {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-base);
    margin-bottom: var(--space-3);
  }
  .win-modal__thanks {
    text-align: center;
    display: none;
  }
}
