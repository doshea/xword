@import 'dimensions';
@import 'design_tokens';

#body > .xw-container {
  padding-inline: 1em;
  max-width: $row-width+2em;
}

#credit-area, #solve-area, #meta-area, #advanced {
  background-image: url("<%= asset_path 'paper.jpeg' %>");
  padding-top: var(--space-4);
  padding-bottom: var(--space-4);
}

#credit-area {
  margin-top: 2.5em;
  margin-bottom: 0;
  padding-bottom: var(--space-2);
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  box-shadow: var(--shadow-paper);
  .xw-col-full {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }
  h1 {
    font-size: var(--text-2xl);
    margin: 0;
    #creator-credit {
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: var(--weight-normal);
      color: var(--color-text-secondary);
      margin-left: var(--space-2);
    }
  }
  #puzzle-controls {
    position: static;
    display: flex;
    align-items: center;
    gap: 0.5em;
    flex-wrap: wrap;

    .smaller {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }
  }
}
#meta-area {
  border-bottom-left-radius: var(--radius-lg);
  border-bottom-right-radius: var(--radius-lg);
  padding-bottom: var(--space-4);
}

table#crossword {
  border-spacing: 0;
  margin-bottom: 0;

  tr {
    background: var(--color-cell-void);
  }
  .cell {
    padding: 0;
    margin: 0;
    border: solid 0.0625em var(--color-cell-border);
    font-size: 1.25em;
    text-align: center;
    text-transform: uppercase;
    width: 1.5em;
    height: 1.5em;
    position: relative;
    background: var(--color-cell-bg);
    overflow: hidden;

    &.void {
      background-color: var(--color-cell-void) !important;
    }
    &:not(.void){
      cursor: text;
    }
    &.selected{
      background-color: var(--color-cell-selected);
    }
    &.selected-word:not(.selected) {
      background-color: var(--color-cell-word);
    }
    .letter {
      line-height: 145%;
      z-index: 1001;
    }
    .cell-num {
      position: absolute;
      top: 0;
      left: 1px;
      font-size: 0.4em;
      line-height: 1em;
    }
    .flag {
      display: none;
      position: absolute;
      width: 0;
      height: 0;
      top: 0;
      right: 1px;
      z-index: 1000;
      border-style: solid;
      border-width: 0 0.35em 0.35em 0;
    }

    .circle {
      height: 100%;
      width: 100%;
      position: absolute;
      border: 1px solid var(--color-cell-border);
      border-radius: 50%;
      top: 0;
    }
  }
}
.flagged .flag  {
  display: block !important;
}
.incorrect .flag {
  border-color: transparent var(--color-danger) transparent transparent;
}
.correct .flag {
  border-color: transparent var(--color-success) transparent transparent;
}

.xw-puzzle-layout {
  display: flex;
  align-items: flex-start;
  gap: 0.5em;
  flex-wrap: wrap;

  .clue-column {
    flex: 1;
    min-width: 12em;       // force flex-wrap when columns would get too narrow
    margin-left: 0;

    .clues {
      width: 100%;
    }
  }
}

// --- Below desktop: stack vertically, grid on top, clues below ---
@media (max-width: #{$bp-lg - 1}) {
  .xw-puzzle-layout {
    flex-direction: column;
    align-items: center;

    .clue-column {
      width: 100%;
      min-width: 0;

      .clues {
        height: auto !important;  // override inline style from HAML
        max-height: 18em;
      }
    }
  }

  // Allow horizontal scroll for grids that overflow (Sunday 21×21)
  #solve-area .xw-col-full {
    overflow-x: auto;
  }
}

// --- Tablet (640-1023px): puzzle on top, clues side-by-side below ---
// Uses CSS Grid to guarantee both clue columns wrap together (no
// asymmetric state where only one column sits beside the puzzle).
@media (min-width: $bp-sm) and (max-width: #{$bp-lg - 1}) {
  .xw-puzzle-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;

    table#crossword {
      grid-column: 1 / -1;
      justify-self: center;
    }
  }

  .xw-reply {
    margin-left: var(--space-4);
  }

  #body > .xw-container {
    padding-inline: var(--space-6);
  }
}

// --- Phone: shrink cells to fit standard 15×15 grid ---
@media (max-width: #{$bp-sm - 1}) {
  table#crossword .cell {
    font-size: 1.05em;   // down from 1.25em → ~25px cells → 15×25=375px
    width: 1.4em;
    height: 1.4em;
  }

  // Team chat: full-width on phones instead of fixed 320px
  #team-chat {
    width: calc(100vw - 2em);
    right: 1em;
    left: 1em;
  }

  // Comments: full-width replies, reduced indent
  .xw-comment__body li { width: 100%; }
  .xw-reply { margin-left: var(--space-3); }

  // Controls modal: single column on phones
  #controls-modal .controls-modal__columns {
    flex-direction: column;
    gap: var(--space-4);
  }
}

// --- XL screens: widen container + scale up cells ---
// At 1280px+, the 1032px container wastes 400+ pixels of space.
// Widen to 1200px and bump cells from 30px → 36px so the puzzle
// feels proportional to the screen. Clue columns auto-widen (flex: 1).
@media (min-width: $bp-xl) {
  #body > .xw-container {
    max-width: 75rem;          // 1200px
    padding-inline: var(--space-8);  // 32px — more breathing room on wide screens
  }
  table#crossword .cell {
    font-size: 1.5em;  // 36px cells (up from 30px)
  }
  #team-chat {
    width: 380px;
    font-size: var(--text-base);
  }
}

.clue-column {
  background: transparent;
  border: none;
  border-left: none;
  margin-left: 0.75em;
  margin-right: 0;
  h3 {
    text-align: center;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
    margin: var(--space-2) var(--space-3) var(--space-3);
  }
  .clues {
    list-style: none;
    position: relative;
    overflow: auto;
    width: 100%;
    overflow-x: hidden;
    background: var(--color-surface-alt);
    box-shadow: var(--shadow-inner);
    border-radius: var(--radius-sm);
    font-size: smaller;
    padding: var(--space-1) var(--space-2);
    height: 31em;

    .clue {
      border: 1px solid transparent;
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-1) 0.25em var(--space-1) 2em;
      text-indent: -1.7em;
      cursor: pointer;

      &.crossed-off {
        text-decoration: line-through;
        opacity: 0.5;
      }

      &.selected-clue {
        background-color: var(--color-cell-word);
        border: 1px solid var(--color-border-strong);
      }
    }
    .clue-num {
      color: var(--color-text-muted);
    }
    input {
      height: 1.5em;
      display: inline-block;
      border: none;
      box-shadow: none;
      background: none;
      margin-bottom: 0;
      cursor: pointer;
      &:focus {
        cursor: text;
      }
    }
  }
}


#solve-controls {
  margin-bottom: var(--space-2);
}

#preview {
  text-align: center;
  canvas {
    display: inline-block;
  }
}
#teammates {
  display: inline-block;
  .teammate-box {
    width: 1em;
    height: 1em;
    box-shadow: var(--shadow-sm);
    display: inline-block;
    margin-right: 0.2em;
  }
}

// --- Team chat widget ---
// Fixed bottom-right tray; toggles via .down class (JS: team_app.toggle_chat)

#team-chat {
  width: 320px;
  position: fixed;
  right: 1.5em;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-bottom: none;
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  bottom: 0;
  transition: transform var(--duration-slow) var(--ease-out);
  z-index: var(--z-dropdown);
  box-shadow: var(--shadow-lg);
  font-family: var(--font-ui);
  font-size: var(--text-sm);

  &.down {
    transform: translateY(calc(100% - 2.2em));
  }

  .row-topper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    height: 2.2em;
    background: var(--color-accent);
    border-top-left-radius: var(--radius-lg);
    border-top-right-radius: var(--radius-lg);
    color: white;
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--duration-base) var(--ease-in-out);

    &:hover { background: var(--color-accent-hover); }

    #chat-minmax {
      position: absolute;
      right: 0.75em;
      display: flex;
    }
    #unread-chat-count {
      font-weight: var(--weight-bold);
    }
  }

  form {
    margin: 0;
    padding: var(--space-2);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-alt);
  }
  input {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    transition: border-color var(--duration-base) var(--ease-in-out);

    &:focus {
      outline: none;
      border-color: var(--color-accent);
    }
  }

  #chats {
    overflow-y: auto;
    max-height: 330px;
    padding: var(--space-2);
  }

  .chat-group {
    display: flex;
    align-items: flex-end;
    gap: var(--space-1);
    margin-bottom: var(--space-2);

    &:last-child { margin-bottom: 0; }

    &--other { flex-direction: row; }
    &--self  { flex-direction: row-reverse; }

    &__avatar {
      width: 1.6em;
      height: 1.6em;
      border-radius: var(--radius-full);
      flex-shrink: 0;
    }

    &__messages {
      display: flex;
      flex-direction: column;
      gap: 2px;
      max-width: 80%;
    }

    &__name {
      font-size: var(--text-xs);
      font-weight: var(--weight-semibold);
      color: var(--color-text-muted);
      padding-left: var(--space-1);
    }
  }

  .chat {
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    border-radius: var(--radius-md);
    background-color: var(--color-surface-alt);
    transition: background-color var(--duration-slow) var(--ease-out);

    &.my-chat {
      text-align: left;
      background-color: var(--color-accent-light);
    }

    &--first {
      .chat-group--other & { border-top-left-radius: var(--radius-sm); }
      .chat-group--self &  { border-top-right-radius: var(--radius-sm); }
    }

    .chat-text {
      max-width: 100%;
      overflow-wrap: break-word;
    }

    &.team-chat-error {
      text-align: center;
      font-style: italic;
      color: var(--color-text-muted);
      font-size: var(--text-sm);
      padding: 0.4em 0;
      background: none;
    }
  }
}

// --- Team explanation modal ---

#team-explanation {
  text-align: center;
  max-width: 32rem;
  position: relative;

  .xw-modal__close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
  }

  h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .team-modal__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }
  .team-modal__url-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .team-modal__url-input {
    flex: 1;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-inner);
    cursor: pointer;
    color: var(--color-text);

    &:focus {
      outline: none;
      border-color: var(--color-accent);
    }
  }
  .team-modal__url-copy {
    background: none;
    border: none;
    color: var(--color-accent);
    flex-shrink: 0;
    cursor: pointer;
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    transition: var(--transition-colors);
    &:hover { background: var(--color-accent-light); }
  }
  .team-modal__footnote {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }
}
// --- Creator byline ---

.xw-byline {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-3) 0 var(--space-3);
  border-bottom: 1px solid var(--color-border);

  &__avatar img {
    width: 64px;
    height: 64px;
    object-fit: cover;
  }
  &__content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  &__desc {
    font-family: var(--font-body);
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-1);
  }
  &__name {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    a {
      color: var(--color-text-secondary);
      text-decoration: none;
      &:hover { text-decoration: underline; }
    }
  }
}

// --- Meta area states ---

.xw-meta-area__empty,
.xw-meta-area__auth-prompt {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--color-text-secondary); // bumped from --color-text-muted for WCAG AA at small sizes
}

// "Enter to send" hint — appears on textarea focus
.xw-comment__hint {
  display: block;
  font-family: var(--font-ui);
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  margin-top: var(--space-1);
  opacity: 0;
  transition: opacity var(--duration-fast) var(--ease-in-out);
}
textarea:focus ~ .xw-comment__hint {
  opacity: 1;
}

// --- Comment divider (invisible; keeps DOM node for Turbo Stream removal) ---

.xw-comment__divider {
  border: none;
  margin: 0;
  height: 0;
}

#comments {
  h2 {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }
  textarea {
    background-color: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    resize: none;
    overflow: auto;
  }
  .xw-textarea--compact {
    height: 2.5rem;
    min-height: 2.5rem;
    transition: height var(--duration-base) var(--ease-out);
    &:focus {
      height: 5rem;
    }
  }
}

// --- Comment & reply layout ---

.xw-comment {
  display: flex;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-2) var(--space-2);
  border-radius: var(--radius-sm);
  transition: background-color var(--duration-base) var(--ease-in-out);

  &:hover {
    background-color: rgba(28, 26, 23, 0.02);
  }

  &__content {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }
  &__author {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    margin-right: 0.4em;
    a {
      color: var(--color-text);
      text-decoration: none;
      &:hover { text-decoration: underline; }
    }
  }

  &__avatar {
    flex-shrink: 0;
    padding-top: 1px; // optical alignment with first line of text
    img {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      object-fit: cover;
    }
  }
  &__body {
    flex: 1;
    min-width: 0;
    position: relative; // anchor for overlay actions

    .xw-comment__actions {
      margin-top: var(--space-1);
    }
    .reply-form {
      width: 70%;
    }
    textarea {
      height: 1em;
      min-height: 2.3em;
    }
  }
  &__reply-count {
    // Button reset (element changed from <p> to <button> for accessibility)
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: var(--weight-medium);
    margin-top: var(--space-1);
    cursor: pointer;
    &:hover { text-decoration: underline; }
    &:not(:empty)::before { content: '\25B8\00a0'; }
  }

  // Overlay actions as a pill at top-right of comment body (pointer devices only)
  @media (hover: hover) {
    .xw-comment__actions:not(.xw-comment__actions--expanded) {
      position: absolute;
      top: 0;
      right: 0;
      margin-top: 0;
      z-index: var(--z-raised);
      background: var(--color-surface);
      border-radius: var(--radius-full);
      padding: var(--space-1) var(--space-2);
      box-shadow: var(--shadow-sm);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-fast) var(--ease-in-out);
      display: flex;
      gap: var(--space-3);
    }
    &:hover .xw-comment__actions:not(.xw-comment__actions--expanded),
    &:focus-within .xw-comment__actions:not(.xw-comment__actions--expanded) {
      opacity: 1;
      pointer-events: auto;
    }
  }
}

.xw-reply {
  display: flex;
  gap: var(--space-2);
  padding: var(--space-1) 0;
  margin-left: var(--space-6);
  position: relative;

  &__avatar {
    flex-shrink: 0;
    img {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      object-fit: cover;
    }
  }
  &__body {
    flex: 1;
    min-width: 0;
  }
}

// Initial display states for reply toggle (jQuery toggle_reply_form manages visibility)
.cancel-button { display: none; }
.reply-form { display: none; }

.reply-button {
  display: inline-flex;
  align-items: center;
  gap: 0.25em;
  cursor: pointer;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  &:hover { color: var(--color-text); }
}

.reply-controls {
  position: absolute;
  top: var(--space-3);
  right: 0;
  display: flex;
  gap: var(--space-2);
  a {
    color: var(--color-text-muted);
    cursor: pointer;
    &:hover { color: var(--color-text); }
  }
}

// Hover-reveal for reply controls (pointer devices only)
@media (hover: hover) {
  .reply-controls {
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-in-out);
  }
  .xw-reply:hover .reply-controls,
  .xw-reply:focus-within .reply-controls {
    opacity: 1;
  }
}
// --- Puzzle Stats sidebar ---

.xw-stats-panel {
  background-color: var(--color-surface-alt);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4) var(--space-4);
  box-shadow: var(--shadow-sm);

  &__heading {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3);
  }
}

.xw-stats-list {
  margin: 0;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: var(--space-1) var(--space-3);
  align-items: baseline;

  dt {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }
  dd {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    text-align: right;
    margin: 0;
  }

  &__divider {
    grid-column: 1 / -1;
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2) 0;
  }

  &__placeholder {
    color: var(--color-text-muted);
    font-style: italic;
  }
}

// Desktop: stats column spans both byline + comments rows
@media (min-width: $bp-lg) {
  .xw-stats-col {
    grid-row: span 2;
  }
  .xw-stats-panel {
    position: sticky;
    top: 1rem;
  }
}

// Phone/tablet: stats stacks below comments with a top border
@media (max-width: #{$bp-lg - 1}) {
  .xw-stats-panel {
    background: transparent;
    border: none;
    border-top: 1px solid var(--color-border);
    border-radius: 0;
    padding: var(--space-3) 0 0;
  }
}

.team-outline {
  position: absolute;
  z-index: 999;
}

// --- Controls modal ---

#controls-modal {
  max-width: 28rem;

  .controls-modal__heading {
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
  }
  .controls-modal__columns {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
  }
  .controls-modal__actions {
    list-style: none;
    padding: 0;
    li {
      font-family: var(--font-ui);
      font-size: var(--text-sm);
      padding: var(--space-1) 0;
      color: var(--color-text-secondary);
    }
  }
  .controls-modal__keys {
    list-style: none;
    padding: 0;
    text-align: right;
    li { padding: var(--space-1) 0; }
  }
  kbd {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.15em 0.5em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-sunken);
    box-shadow: 0 1px 0 var(--color-border-strong);
    min-width: 2em;
    text-align: center;
  }
  .controls-modal__arrow-key {
    min-width: 1.5em;
    padding: 0.15em 0.3em;
  }
}

// --- Win modal ---

#win-modal {
  text-align: center;

  .win-modal__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .win-modal__congrats {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }
  .win-modal__subtitle {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }
  .win-modal__time {
    margin-bottom: var(--space-4);
  }
  .win-clock {
    display: inline-block;
    background: var(--color-nav-bg);
    color: var(--color-surface);
    padding: 2px var(--space-2) 0;
    border-radius: var(--radius-sm);
  }
  .win-clock__segment {
    display: inline-block;
  }
  .win-clock__separator {
    vertical-align: top;
    line-height: 37px;
  }
  .win-clock__ms-dot {
    position: relative;
    bottom: 7px;
  }
  .win-modal__prompt {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-base);
    margin-bottom: var(--space-3);
  }
  .win-modal__thanks {
    text-align: center;
    display: none;
  }
}
