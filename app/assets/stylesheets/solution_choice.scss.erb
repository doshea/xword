tr:hover{
  button {
    transform: scale(2, 1) translateX(-12%);
  }
  .hidden-canvas {
    background-color: rgba(0,0,0,0);
    border-radius: 0em;
  }
}
tr:not(:hover){
  .hidden-canvas {
    opacity: 0;
    top: 0 !important;
    left: 0 !important;
    transform: scale(0);
    visibility: hidden;
  }
  a {
    color: inherit;
  }
  button {
    opacity: 0.5;
  }
}
.hidden-canvas {
  position: absolute;
  margin: 0;
  transition: all 0.3s linear;
  background-color: rgba(43, 166, 203, 0.5);
}
table {
  margin: 0.5em 0 1.5em 1em;
}
button, form {
  margin: 0;
  transition: all 0.3s;
}
button {
  padding: 0.5em 1em;
}
.xw-icon {
  transition: all 0.3s;
  &.xw-icon--trash-2:hover {
    color: #f04124;
  }
}
a {
  transition: all 0.3s;
}
a.not-blue {
  color: inherit;
}
tbody td{
  cursor: pointer;
  position: relative;
  .delete-td {
    cursor: inherit;
  }
}
canvas {
  float: left;
  margin: 1em 1em 0;
}
hr {
  border-width: 0 0 1px;
  padding-top: 1em;
}
.metadata {
  padding-top: 0.5em;
}
