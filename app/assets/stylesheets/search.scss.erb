$standard-img-dim: 75px;

.puzzle-tabs {
  padding: 1em;

  // Multi-column grid for crossword card lists — replaces Foundation .large-3.columns
  // that was removed from _crossword_tab.html.haml in Phase 3.
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 0.5em;
    margin-bottom: 1em;
  }

  .result-user {
    text-align: center;
    border-radius: 1em;
    filter: grayscale(80%);
    transition: all 0.6s;
    &:hover {
      filter: grayscale(0%);
      background: lightgrey;
    }
    img {
      margin-top: 0.5em;
    }
    p.name {
      text-align: center;
    }
  }
}

.result-crossword {
  border: 1px dotted lightgrey;
  transition: background 0.4s;
  &:hover{
    background: lightgrey;
  }
  .xw-grid {
    padding: 0.5em 0;
    .metadata {
      padding-left: 1.2em;
      p {
        margin: 0;
        &.title {
          font-weight: bold;
          font-size: smaller;
          line-height: 1em;
        }
        &.byline {
          font-style: italic;
          font-size: smaller;
        }
        &.dimensions {
          font-size: smaller;
        }
      }
    }
  }
  .minipic img {
    max-width: none;
    width: $standard-img-dim;
    height: $standard-img-dim;
  }
}

.puzzle-tabs {
  a {
    color: inherit;
  }
  p {
    margin: 0;
  }
}

.nyt-watermark {
  position: absolute;
  right: 1em;
  bottom: 0.5em;
  height: 1.5em;
}
