$standard-img-dim: 75px;

.puzzle-tabs {
  padding: var(--space-4);

  // Multi-column grid for crossword card lists — replaces Foundation .large-3.columns
  // that was removed from _crossword_tab.html.haml in Phase 3.
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .result-user {
    text-align: center;
    border-radius: var(--radius-lg);
    filter: grayscale(80%);
    transition: all var(--duration-slower) var(--ease-in-out);
    &:hover {
      filter: grayscale(0%);
      background: var(--color-surface-alt);
    }
    img {
      margin-top: var(--space-2);
    }
    p.name {
      text-align: center;
    }
  }
}

.result-crossword {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  transition: background var(--duration-slow) var(--ease-in-out);
  &:hover {
    background: var(--color-surface-alt);
  }
  .xw-grid {
    padding: var(--space-2) 0;
    .metadata {
      padding-left: var(--space-4);
      p {
        margin: 0;
        &.title {
          font-weight: var(--weight-semibold);
          font-size: var(--text-sm);
          line-height: var(--leading-tight);
        }
        &.byline {
          font-style: italic;
          font-size: var(--text-sm);
        }
        &.dimensions {
          font-size: var(--text-sm);
          color: var(--color-text-muted);
        }
      }
    }
  }
  .minipic img {
    max-width: none;
    width: $standard-img-dim;
    height: $standard-img-dim;
  }
}

.puzzle-tabs {
  a {
    color: inherit;
  }
  p {
    margin: 0;
  }
}

.nyt-watermark {
  position: absolute;
  right: var(--space-4);
  bottom: var(--space-2);
  height: 1.5em;
}
