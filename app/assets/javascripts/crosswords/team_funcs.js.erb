// Converted from team_funcs.js.coffee.erb
// ActionCable-based real-time team solving: sends/receives cell updates, roster changes, chat, and clue highlights.
// display_name and solver_id are pre-set on window.team_app by the view before this file loads.

window.team_app = {
  solver_red:            Math.floor(Math.random() * 266),  // random RGB color identifies this solver
  solver_green:          Math.floor(Math.random() * 266),
  solver_blue:           Math.floor(Math.random() * 266),
  cell_clack_sound:      new Audio('<%= audio_path("chuck.mp3") %>'),
  last_clack:            null,
  message_received_sound: new Audio('<%= audio_path("submarine.m4a") %>'),
  last_received:         null,
  unread_count:          0,
  last_chat_sender:      null,
  display_name:          team_app.display_name,  // copied from view-injected stub
  solver_id:             team_app.solver_id,
  cellTimestamps:        {},  // maps "row,col" → last server_time (ms) for LWW gating
  outline_timers:        {},  // per-solver timeout IDs for clue outline fade-out

  // Toggle the team chat tray open/closed; reset unread count when opening
  toggle_chat: function() {
    $('#team-chat').toggleClass('down');
    if (!$('#team-chat').hasClass('down')) {
      team_app.unread_count = 0;
      $('#unread-chat-count').text('');
    }
    var CHEVRON_UP   = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="xw-icon xw-icon--chevron-up" aria-hidden="true"><path d="m18 15-6-6-6 6" /></svg>';
    var CHEVRON_DOWN = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="xw-icon xw-icon--chevron-down" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>';
    var $minmax = $('#chat-minmax');
    $minmax.html($('#team-chat').hasClass('down') ? CHEVRON_UP : CHEVRON_DOWN);
  },

  //------------------
  // ACTIONCABLE SENDS
  //------------------

  // PATCH → server → ActionCable: broadcasts this solver's cell change to all teammates
  send_team_cell: function($cell, letter) {
    var key = $cell.data('row') + ',' + $cell.data('col');
    team_app.cellTimestamps[key] = Infinity; // protect cell until our echo returns
    var token = $('#crossword').data('auth-token');
    $.ajax({
      type: 'PATCH',
      url:  '/solutions/' + solve_app.solution_id + '/team_update',
      data: {
        authenticity_token: token,
        letter:    letter,
        col:       $cell.data('col'),
        row:       $cell.data('row'),
        solver_id: team_app.solver_id,
        red:       team_app.solver_red,
        green:     team_app.solver_green,
        blue:      team_app.solver_blue
      }
    });
  },

  // POST → server → ActionCable: announces this solver joined; teammates add to roster
  join_team: function() {
    var token = $('#crossword').data('auth-token');
    $.ajax({
      type: 'POST',
      url:  '/solutions/' + solve_app.solution_id + '/join_team',
      data: {
        authenticity_token: token,
        display_name: team_app.display_name,
        red:          team_app.solver_red,
        green:        team_app.solver_green,
        blue:         team_app.solver_blue,
        solver_id:    team_app.solver_id
      }
    });
  },

  // POST → server → ActionCable: announces departure; teammates remove from roster
  leave_team: function() {
    var token = $('#crossword').data('auth-token');
    $.ajax({
      type: 'POST',
      url:  '/solutions/' + solve_app.solution_id + '/leave_team',
      data: {
        authenticity_token: token,
        solver_id: team_app.solver_id
      }
    });
  },

  // POST → server → ActionCable: asks all participants to re-announce themselves
  // TODO: Figure out why this isn't properly getting all teammates
  roll_call: function() {
    var token = $('#crossword').data('auth-token');
    $.ajax({
      type: 'POST',
      url:  '/solutions/' + solve_app.solution_id + '/roll_call',
      data: { authenticity_token: token }
    });
  },

  // POST → server → ActionCable: broadcasts which clue this solver is currently viewing
  // TODO: Figure out why this isn't properly getting all teammates
  show_team_clue: function() {
    var token    = $('#crossword').data('auth-token');
    var cell_num = $(this).data('cell-num');
    var across   = $(this).hasClass('across-clue');
    $.ajax({
      type: 'POST',
      url:  '/solutions/' + solve_app.solution_id + '/show_team_clue/',
      data: {
        authenticity_token: token,
        cell_num:  cell_num,
        across:    across,
        red:       team_app.solver_red,
        green:     team_app.solver_green,
        blue:      team_app.solver_blue,
        solver_id: team_app.solver_id
      }
    });
  },

  //------------------
  // ACTIONCABLE RECEIVES
  //------------------

  // Another solver typed a letter — last-writer-wins via server_time gating.
  // Own echo: record timestamp (downgrades Infinity), don't touch display.
  // Teammate newer: apply edit, record timestamp. Teammate stale: drop silently.
  receive_team_cell: function(data) {
    var key       = data.row + ',' + data.col;
    var stored    = team_app.cellTimestamps[key] || 0;
    var timestamp = data.server_time || 0;

    if (team_app.solver_id === data.solver_id) {
      // Own echo — record the real server timestamp (replaces Infinity)
      team_app.cellTimestamps[key] = timestamp;
      return;
    }

    // Stale broadcast from a teammate — drop silently
    if (timestamp <= stored) return;

    // Newer teammate edit — apply it
    team_app.cellTimestamps[key] = timestamp;

    var $cell = $(".cell[data-row=" + data.row + "][data-col=" + data.col + "]");
    var now   = Date.now();
    if (!(team_app.last_clack && (now - team_app.last_clack < 4000))) {
      team_app.last_clack = now;
      team_app.cell_clack_sound.play();
    }
    $cell.children('.flag').stop()
      .css('background', 'rgb(' + data.red + ', ' + data.green + ', ' + data.blue + ')')
      .animate({opacity: 1}, 300).delay(300).animate({opacity: 0}, 200);
    if (data.letter === '') {
      $cell.delete_letter(false);
    } else {
      $cell.set_letter(data.letter, false);
    }
  },

  // Teammate joined: add a colored square to the on-screen roster
  welcome_teammate: function(data) {
    if ($(".teammate-box[solver_id=" + data.solver_id + "]").length === 0) {
      var teammate = $('<div>');
      teammate.addClass('teammate-box has-tip')
        .css('background', 'rgb(' + data.red + ', ' + data.green + ', ' + data.blue + ')')
        .attr('data-tooltip', true)
        .attr('title', data.display_name)
        .attr('solver_id', data.solver_id);
      $('#teammates').append(teammate);
    }
  },

  // Teammate left: fade out and remove their roster square
  farewell_teammate: function(data) {
    console.log('So long, farewell');
    $("#teammates .teammate-box[solver_id=" + data.solver_id + "]").fadeOut(1000, function() {
      $(this).remove();
    });
  },

  // Chat message received: group consecutive messages from the same speaker (iMessage-style)
  receive_chat: function(data) {
    var is_my_chat  = (team_app.display_name === data['display_name']);
    var sender_key  = data['display_name'];
    var $chats      = $('#chats');
    var $lastChild  = $chats.children().last();
    var $lastGroup  = $lastChild.hasClass('chat-group') ? $lastChild : $();
    var sameSender  = (team_app.last_chat_sender === sender_key) && $lastGroup.length > 0;

    // Build the bubble
    var new_chat  = $('<div>').addClass('chat');
    var chat_text = $('<span>').text(data['chat_text']).addClass('chat-text');
    if (is_my_chat) new_chat.addClass('my-chat');
    chat_text.appendTo(new_chat);

    if (sameSender) {
      // Append to existing group
      $lastGroup.find('.chat-group__messages').append(new_chat);
    } else {
      // Create new group
      var $group    = $('<div>').addClass('chat-group');
      var $messages = $('<div>').addClass('chat-group__messages');

      new_chat.addClass('chat--first');

      if (is_my_chat) {
        $group.addClass('chat-group--self');
      } else {
        $group.addClass('chat-group--other');
        var $avatar = $('<img>').attr('src', data['avatar']).addClass('chat-group__avatar');
        var $name   = $('<span>').text(data['display_name']).addClass('chat-group__name');
        $messages.append($name);
        $group.append($avatar);
      }

      $messages.append(new_chat);
      $group.append($messages);
      $chats.append($group);
      team_app.last_chat_sender = sender_key;
    }

    // Amber flash, sound throttle, unread count for other people's messages
    if (!is_my_chat) {
      new_chat.css({'background-color': '#fdf0e4'});
      if ($('#team-chat').hasClass('down')) {
        team_app.unread_count += 1;
        $('#unread-chat-count').text('(' + team_app.unread_count + ')');
      }
      var now = Date.now();
      if (!(team_app.last_received && (now - team_app.last_received < 8000))) {
        team_app.last_received = now;
        team_app.message_received_sound.play();
      }
      window.setTimeout(function() { new_chat.css({'background-color': ''}); }, 400);
    }
    var scroll_height = $chats.get(0).scrollHeight;
    $chats.stop().animate({scrollTop: scroll_height}, 'fast');
  },

  // Teammate clicked a clue: draw a dashed outline over those cells for 20 seconds
  outline_team_clue: function(data) {
    if (data.solver_id !== team_app.solver_id) {
      var outline_width = 2;
      var outline_id    = data.solver_id + '_word_highlight';
      var outline_color = data.red + ', ' + data.green + ', ' + data.blue;
      var the_outline   = $('#' + outline_id);

      if (!the_outline.get(0)) {
        the_outline = $("<div id='" + outline_id + "'>");
        the_outline.addClass('team-outline').hide()
          .css('border', outline_width + 'px dashed rgb(' + outline_color + ')')
          .css('background-color', 'rgba(' + outline_color + ', 0.2)');
        $('body').append(the_outline);
      }

      var across     = data['across'] === 'true';
      var start_cell = $(".cell[data-cell=" + data.cell_num + "]");
      var word_cells = across ? start_cell.get_across_word_cells() : start_cell.get_down_word_cells();
      var n          = word_cells.length;
      var h          = across ? word_cells[0].height() - 3 : word_cells[0].height() * n + 2 * n - 5;
      var w          = across ? word_cells[0].width()  * n + 2 * n - 5 : word_cells[0].width()  - 3;

      the_outline.height(h).width(w)
        .offset({ top: word_cells[0].offset().top + 1, left: word_cells[0].offset().left + 1 })
        .stop().css('opacity', 1).show();

      // Per-solver timer so multiple teammates' outlines fade independently
      if (team_app.outline_timers[data.solver_id]) clearTimeout(team_app.outline_timers[data.solver_id]);
      team_app.outline_timers[data.solver_id] = setTimeout(function() {
        the_outline.animate({'opacity': 0}, 'fast');
      }, 20000);
    }
  }
};

//------------------
// DOCUMENT LOAD
//------------------
// Subscribe to the ActionCable channel and dispatch team event handlers.
// Use turbo:load so team initialization runs after Turbo Drive replaces the body.
// Remove+re-add to prevent duplicate listeners if the script re-executes.
function team_funcs_ready() {
  var teamModal = document.getElementById('team-explanation');
  if (teamModal) teamModal.showModal();

  var EVENT_HANDLERS = {
    change_cell:       team_app.receive_team_cell,
    join_puzzle:       team_app.welcome_teammate,
    leave_puzzle:      team_app.farewell_teammate,
    roll_call:         team_app.join_team,
    chat_message:      team_app.receive_chat,
    outline_team_clue: team_app.outline_team_clue
  };

  // Disconnect previous consumer/subscription to prevent duplicate message processing
  if (team_app._consumer) {
    team_app._consumer.disconnect();
  }
  team_app._consumer = ActionCable.createConsumer();
  team_app._consumer.subscriptions.create(
    { channel: 'TeamsChannel', team_key: team_key },
    {
      received: function(data) {
        var handler = EVENT_HANDLERS[data.event];
        if (handler) handler(data);
      }
    }
  );

  team_app.roll_call();
  $('#team-chat .row-topper').on('click', team_app.toggle_chat);
  $('.clue').on('click', team_app.show_team_clue);
  // Remove previous unload handler before adding to prevent stacking
  $(window).off('unload', team_app.leave_team);
  $(window).on('unload', team_app.leave_team);
}

if (window._teamTurboLoadHandler) document.removeEventListener("turbo:load", window._teamTurboLoadHandler);
window._teamTurboLoadHandler = function() {
  if (!$('#team-chat').length) return; // not on a team solve page
  team_funcs_ready();
};
document.addEventListener("turbo:load", window._teamTurboLoadHandler);
// When Turbo navigates to the team page and executes this body script,
// turbo:load has already fired. Run immediately if the DOM is ready.
if (document.readyState !== 'loading' && $('#team-chat').length) {
  team_funcs_ready();
}
