// Animates the signup slider on the welcome/landing page.

window.welcome = {
  ready: function() {
    $('#signup1').on('click', welcome.slide_left);
    $('#signup2').on('click', welcome.slide_right);
  },

  slide_left: function(e) {
    e.preventDefault();
    $('.slider').animate({'marginLeft': "-=23.3em"});
  },

  slide_right: function(e) {
    e.preventDefault();
    $('.slider').animate({'marginLeft': "+=23.3em"});
  }
};

// Use turbo:load so welcome.ready() runs after Turbo Drive replaces the body.
// Remove+re-add to prevent duplicate listeners if the script re-executes.
if (window._welcomeTurboLoadHandler) document.removeEventListener("turbo:load", window._welcomeTurboLoadHandler);
window._welcomeTurboLoadHandler = function() {
  if (!$('#signup1').length) return; // not on the welcome page
  welcome.ready();
};
document.addEventListener("turbo:load", window._welcomeTurboLoadHandler);
