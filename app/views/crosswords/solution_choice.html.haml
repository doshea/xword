-# This page is only shown to users if they have worked on multiple solutions to the same crossword
= content_for :head do
  = stylesheet_link_tag :solution_choice

= render layout: 'layouts/partials/topper_stopper', locals: {row_top_title: 'Choose a Solution', custom_columns: true} do
  .xw-col-12.xw-lg-4
    - if @crossword.preview.present?
      = image_tag(@crossword.preview.url, class: 'xw-thumbnail')
    .metadata
      %h2= @crossword.title
      %p= @crossword.user&.display_name || '[Deleted Account]'
      %p
        #{@crossword.rows} x #{@crossword.cols}
        %br
        #{@crossword.nonvoid_letter_count} empty cells
    %hr
    %p
      You have more than one solution for this crossword. Please choose the one you would like to work on.
  .xw-col-12.xw-lg-8
    -# The table of available solutions
    %table.xw-solutions-table
      %thead
        %tr
          %th
            -# Blank column for Arrow button
          %th
            -# Blank column for Team status
          %th Correct
          %th Complete
          %th Last Worked On
          %th Started
          %th Delete
      %tbody
        - @solutions.each do |solution|
          - solution_correctness = solution.percent_correct
          - solution_completion = solution.percent_complete
          %tr{data: {link: solution_path(solution)}}
            %td
              = link_to solution_path(solution) do
                = icon('arrow-left')
            %td
              = icon(solution.team ? 'users' : 'user')
            %td #{solution_correctness[:percent]}%
            %td #{solution_completion[:percent]}%
            %td #{distance_of_time_in_words_to_now(solution.updated_at, {include_seconds: true})} ago
            %td #{distance_of_time_in_words_to_now(solution.created_at, {include_seconds: true})} ago
            %td.trash-td
              / Replaced: link_to with method: :delete → turbo_method: :delete (Turbo handles DELETE)
              = link_to(delete_solution_path(solution), class: 'not-blue', data: { turbo_method: :delete, turbo_confirm: @current_user == solution.user ? (solution.team ? 'Are you SURE you want to delete this solution? You and the rest of your team will PERMANENTLY lose your work!' : 'Are you SURE you want to delete your solution? You worked so hard on it!') : 'Are you SURE you want to leave this team solution?' }) do
                = icon('trash-2')
          - if solution.team
            - members = [solution.user&.display_name || '[deleted]'] + solution.teammates.map(&:display_name)
            %tr.xw-solutions-table__members
              %td{colspan: 7}
                %span.xw-solutions-table__members-label Collaborators:
                = members.join(', ')
= javascript_include_tag 'solution_choice', 'data-turbo-track': 'reload'
