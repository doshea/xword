- title @crossword.title, true
= content_for :head do
  = stylesheet_link_tag "crossword"
  = javascript_include_tag 'solve', 'data-turbo-track': 'reload'
  %meta{property: 'og:image', content: @crossword.preview.large.url}

- if @team
  = render partial: 'crosswords/partials/team'

:javascript
  solve_app.solution_id = #{@solution.try(:id).to_json}
  solve_app.crossword_id = #{@crossword.try(:id).to_json}
  solve_app.anonymous = #{@current_user.nil?.to_json}
  solve_app.started_at = #{(@solution ? (@solution.created_at.to_f * 1000).round : 'null')}
  solve_app.is_complete = #{@solution&.is_complete? ? 'true' : 'false'}

- unless @current_user
  .xw-alert.xw-alert--info{data: {controller: 'alert'}}
    Sign up for free to save your progress!
    = link_to 'Sign up', new_user_path, class: 'xw-btn xw-btn--sm'
    %button.xw-alert__dismiss{data: {action: 'click->alert#dismiss'}, aria: {label: 'Dismiss'}} &times;
- if @crossword.user && (@current_user == @crossword.user)
  .xw-alert.xw-alert--info{data: {controller: 'alert'}}
    .center You are the creator of this puzzle
    %button.xw-alert__dismiss{data: {action: 'click->alert#dismiss'}, aria: {label: 'Dismiss'}} &times;

-# Sunday crosswords need a wider container on desktop; mobile scrolls horizontally
- if @crossword.cols > 15
  :css
    @media (min-width: 1024px) {
      #body > .xw-container { max-width: none; width: 1250px; }
    }
:css
  .clue-column .clues {
    height: #{@crossword.rows*2.175-22/16.0}em;
  }
  @media (min-width: 1280px) {
    .clue-column .clues {
      height: #{@crossword.rows*2.61-22/16.0}em;
    }
  }

%header.xw-container.xw-grid#credit-area
  .xw-col-full
    %h1
      = @crossword.title
      %span#creator-credit= "by #{@crossword.user&.display_name || '[Deleted Account]'}"
    #puzzle-controls.no-select
      - if @current_user
        %span#save-status.smaller No changes yet
      %span#save-clock.smaller
      - if @current_user
        %button#solve-save.xw-btn.xw-btn--sm.xw-btn--ghost{type: 'button', data: {'xw-tooltip': 'Save'}, aria: {label: 'Save'}}
          = icon('save')
        = render partial: 'crosswords/partials/favorites_toggle', locals: { crossword: @crossword, current_user: @current_user }
        %button#controls-button.xw-btn.xw-btn--sm.xw-btn--ghost{type: 'button', data: {'xw-tooltip': 'Controls'}, aria: {label: 'Puzzle controls'}}
          = icon('settings')
        / Replaced: link_to with method: :delete → turbo_method: :delete (Turbo handles DELETE)
        = link_to(delete_solution_path(@solution), class: 'xw-btn xw-btn--sm xw-btn--ghost', data: { turbo_method: :delete, turbo_confirm: @current_user == @solution.user ? (@solution.team ? 'Are you SURE you want to delete this solution? You and the rest of your team will PERMANENTLY lose your work!' : 'Are you SURE you want to abandon your solution? You worked so hard on it!') : 'Are you SURE you want to leave this team solution?', 'xw-tooltip': 'Delete Solution' }, aria: { label: 'Delete solution' }) do
          = icon('trash-2')
      - if @team
        %button.xw-btn.xw-btn--sm.xw-btn--secondary{type: 'button', onclick: "document.getElementById('team-explanation').showModal()", data: {'xw-tooltip': 'Team Solve'}, aria: {label: 'Team Solve'}}
          = icon('users')
          %span#teammates
      - elsif @current_user
        / Replaced: link_to with method: 'post' → turbo_method (Turbo handles POST for non-GET links)
        = link_to create_team_crossword_path(@crossword), class: 'xw-btn xw-btn--sm xw-btn--secondary', id: 'solve-share', data: { turbo_method: :post, 'xw-tooltip': 'Team Solve' }, aria: { label: 'Solve with a team' } do
          = icon('users')
          Team


%section.xw-container.xw-grid#solve-area{aria: {label: 'Puzzle grid'}}
  .xw-col-full
    = render partial: 'crosswords/partials/solve_crossword'
%section.xw-container.xw-grid#meta-area{aria: {label: 'Puzzle information'}}
  .xw-col-full
    #solve-controls
      -# %button.button.warning.small#show-incorrect
      -#   %i.fi-alert
      -#   Show Incorrect
      .xw-dropdown{data: {controller: 'dropdown'}}
        %button.xw-btn.xw-btn--sm.xw-btn--success.check-completion{data: {action: 'click->dropdown#toggle', unhighlight: 'false'}}
          = icon('check')
          Check ▾
        %ul.xw-dropdown-menu{data: {dropdown_target: 'menu'}}
          %li
            %a#check-cell{:href => "#"} Current Cell
          %li
            %a#check-word{:href => "#"} Current Word
          %li
            %a#check-puzzle{:href => "#"} Entire Puzzle
          %hr
          %li.check-completion
            %a{:href => "#"} Completion
          %hr
          %li
            %a#reveal-letter{:href => "#"} Reveal Letter
          %li
            %a#hint-word{:href => "#"} Hint Word
      - if @has_multiple_solutions
        = link_to solution_choice_crossword_path(@crossword), class: 'xw-btn xw-btn--sm xw-btn--ghost', data: { 'xw-tooltip': 'Switch solution' }, aria: { label: 'Switch solution' } do
          = icon('refresh-cw')
          Switch
      - if is_admin?
        .xw-dropdown{data: {controller: 'dropdown'}}
          %button.xw-btn.xw-btn--sm.xw-btn--ghost{data: {action: 'click->dropdown#toggle'}}
            = icon('tool')
            Admin ▾
          %ul.xw-dropdown-menu{data: {dropdown_target: 'menu'}}
            %li
              %a#admin-fake-win{:href => "#"} Fake Win
            %hr
            %li
              %a#admin-reveal-puzzle{:href => "#"} Reveal Puzzle
            %li
              %a#admin-clear-puzzle{:href => "#"} Clear Puzzle
            %hr
            %li
              %a#admin-flash-cascade{:href => "#"} Flash Cascade
  .xw-col-12.xw-lg-8
    .xw-byline
      - if @crossword.user && !@crossword.user.deleted?
        = link_to @crossword.user, class: 'xw-byline__avatar' do
          = image_tag(@crossword.user.image.creator_pic.url)
      - elsif @crossword.user
        .xw-byline__avatar
          = image_tag(@crossword.user.image.creator_pic.url, alt: 'Deleted Account')
      .xw-byline__content
        - if @crossword.description.present?
          %p.xw-byline__desc= @crossword.description
          %button.xw-byline__more{type: 'button'} more
        - if @crossword.user && !@crossword.user.deleted?
          %p.xw-byline__name
            &mdash;
            = link_to @crossword.user.display_name, @crossword.user
        - elsif @crossword.user
          %p.xw-byline__name
            &mdash;
            = @crossword.user.display_name
  .xw-col-12.xw-lg-4.xw-stats-col
    = render partial: 'crosswords/partials/puzzle_stats'
  .xw-col-12.xw-lg-8
    %section#comments{aria: {labelledby: 'comments-heading'}}
      %h2#comments-heading Comments
      - if @current_user
        / Replaced: form_tag with remote: true → form_with (Turbo handles AJAX; id kept for add_comment.turbo_stream.erb target)
        = form_with(url: add_comment_path(@crossword), id: 'comment-form', data: { controller: 'loading', action: 'submit->loading#submit' }) do |f|
          = text_area_tag('content', nil, id: 'add-comment', class: 'xw-textarea xw-textarea--compact', rows: 1, autocomplete: 'off', placeholder: 'Add a comment...', aria: {label: 'Add a comment'})
          %span.xw-comment__hint Enter to send
      - else
        %p.xw-meta-area__auth-prompt
          = link_to 'Sign up', new_user_path
          or
          = link_to 'Log in', login_path
          to comment on this puzzle
      - if @comments.empty?
        %p.xw-meta-area__empty No comments yet
      - @comments.each do |comment|
        = render partial: 'comments/partials/comment', locals: {comment: comment}

= render partial: 'solutions/partials/win_modal'
= render partial: 'crosswords/partials/controls_modal'