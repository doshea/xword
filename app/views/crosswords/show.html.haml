- title @crossword.title, true
= content_for :head do
  = stylesheet_link_tag "crossword"
  = javascript_include_tag 'solve', 'data-turbo-track': 'reload'
  %meta{property: 'og:image', content: @crossword.preview.large.url}

- if @team
  = render partial: 'crosswords/partials/team'

:javascript
  solve_app.solution_id = #{@solution.try(:id).to_json}
  solve_app.crossword_id = #{@crossword.try(:id).to_json}
  solve_app.anonymous = #{@current_user.nil?.to_json}

- if (@current_user == @crossword.user)
  .xw-alert.xw-alert--info{data: {controller: 'alert'}}
    .center
      You are the creator of this puzzle
      -if !@crossword.published
        %br
        = link_to('Edit Puzzle', edit_crossword_path(@crossword))
        or
        = link_to('Publish Puzzle', publish_crossword_path(@crossword), data: { turbo_confirm: 'Are you sure you want to publish this puzzle?\nPublished puzzles cannot be edited or deleted.' })
    %button.xw-alert__dismiss{data: {action: 'click->alert#dismiss'}, aria: {label: 'Dismiss'}} &times;

-# Quick fix for sunday crosswords. TODO fix this.
- if @crossword.cols > 15
  :css
    #body > .xw-container {
      max-width: none;
      width: 1250px;
    }
:css
  .clue-column .clues {
    height: #{@crossword.rows*2.175-22/16.0}em;
  }

%header.xw-container.xw-grid#credit-area
  .xw-col-full
    %h1
      = @crossword.title.html_safe
      %span#creator-credit= "by #{ @crossword.user.present? ? @crossword.user.display_name : '[deleted]' }"
    #puzzle-controls.no-select
      - if @current_user
        %span#save-status.smaller No changes yet
      %span#save-clock.smaller
      - if @current_user
        %a#solve-save.xw-btn.xw-btn--sm.xw-btn--secondary{href: '#', title: 'Quicksave', aria: {label: 'Quicksave'}}
          = icon('save')
        / Replaced: link_to with method: :post/:delete, remote: true → turbo_method (Turbo handles AJAX)
        / Wrapped in #favorites-toggle so favorite_unfavorite.turbo_stream.erb can replace both buttons together
        #favorites-toggle
          = link_to(favorite_crossword_path(@crossword), title: 'Favorite', class: "xw-btn xw-btn--sm xw-btn--secondary#{@is_favorited ? ' hidden' : ''}", id: 'favorite', data: { turbo_method: :post }, aria: { label: 'Add to favorites' }) do
            = icon('star')
          = link_to(favorite_crossword_path(@crossword), title: 'Unfavorite', class: "xw-btn xw-btn--sm xw-btn--secondary#{@is_favorited ? '' : ' hidden'}", id: 'unfavorite', data: { turbo_method: :delete }, aria: { label: 'Remove from favorites' }) do
            = icon('star', style: 'color: #ff7878;')
        = link_to '#', id: 'controls-button', title: 'Controls', class: 'xw-btn xw-btn--sm xw-btn--secondary', aria: { label: 'Puzzle controls' } do
          = icon('settings')
        / Replaced: link_to with method: :delete → turbo_method: :delete (Turbo handles DELETE)
        = link_to(delete_solution_path(@solution), class: 'xw-btn xw-btn--sm xw-btn--secondary', data: { turbo_method: :delete, turbo_confirm: @current_user == @solution.user ? (@solution.team ? 'Are you SURE you want to delete this solution? You and the rest of your team will PERMANENTLY lose your work!' : 'Are you SURE you want to abandon your solution? You worked so hard on it!') : 'Are you SURE you want to leave this team solution?' }, aria: { label: 'Delete solution' }) do
          = icon('trash-2')
      - if @team
        .xw-btn.xw-btn--sm.xw-btn--secondary
          = icon('users')
          #teammates
      - else
        / Replaced: link_to with method: 'post' → turbo_method (Turbo handles POST for non-GET links)
        = link_to create_team_crossword_path(@crossword), class: 'xw-btn xw-btn--sm xw-btn--secondary', id: 'solve-share', title: 'Solve collaboratively', data: { turbo_method: :post }, aria: { label: 'Solve with a team' } do
          = icon('users')
          Team


%section.xw-container.xw-grid#solve-area{aria: {label: 'Puzzle grid'}}
  .xw-col-full
    = render partial: 'crosswords/partials/solve_crossword'
%section.xw-container.xw-grid#meta-area{aria: {label: 'Puzzle information'}}
  .xw-col-full
    #solve-controls
      -# %button.button.warning.small#show-incorrect
      -#   %i.fi-alert
      -#   Show Incorrect
      .xw-dropdown{data: {controller: 'dropdown'}}
        %button.xw-btn.xw-btn--sm.xw-btn--success.check-completion{data: {action: 'click->dropdown#toggle', unhighlight: 'false'}}
          = icon('check')
          Check ▾
        %ul.xw-dropdown-menu{data: {dropdown_target: 'menu'}}
          %li
            %a#check-cell{:href => "#"} Current Cell
          %li
            %a#check-word{:href => "#"} Current Word
          %li
            %a#check-puzzle{:href => "#"} Entire Puzzle
          %hr
          %li.check-completion
            %a{:href => "#"} Completion
      %br
  %hr
  .xw-col-full
    .xw-grid
      .xw-col-12.xw-md-2
        = link_to @crossword.user do
          = image_tag(@crossword.user.image.creator_pic.url, class: 'small-shadow thin-border')
      .xw-col-12.xw-md-10
        %p
          %em= @crossword.description
          &mdash;
          = link_to @crossword.user.display_name, @crossword.user
    %hr
    %section#comments{aria: {labelledby: 'comments-heading'}}
      %h2#comments-heading
        = icon('message-square')
        Comments
      / Feed Entry
      -if @current_user
        / Replaced: form_tag with remote: true → form_with (Turbo handles AJAX; id kept for add_comment.turbo_stream.erb target)
        = form_with(url: add_comment_path(@crossword), id: 'comment-form') do |f|
          = text_area_tag('content', nil, id: 'add-comment', class: 'xw-textarea', placeholder: 'What did you think of this crossword?')
      -else
        =link_to 'Sign up', new_user_path
        or
        = link_to 'Log in', login_path
        to comment on this puzzle
      %hr
      - @comments.each do |comment|
        = render partial: 'comments/partials/comment', locals: {comment: comment}

= render partial: 'solutions/partials/win_modal'
= render partial: 'crosswords/partials/controls_modal'