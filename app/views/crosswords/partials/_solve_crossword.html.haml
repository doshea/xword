.xw-puzzle-layout
  %table#crossword.no-select{data: {id: @crossword.id, rows: @crossword.rows, cols: @crossword.cols}, aria: {label: "#{@crossword.title} crossword grid"}}
    - i = 0
    - for r in 1..@crossword.rows
      %tr{:'data-row' => r}
        - for c in 1..@crossword.cols
          - letter = @crossword.letters[i]
          - unless letter == '_'
            %td.cell{:'data-row' => r, :'data-col' => c, :'data-index' => i, class: ('flagged revealed' if @revealed_set&.include?(i))}
              .flag
              - if @solution
                - sol_content = @solution.rebus_map&.dig(i.to_s) || @solution.letters[i]
                .letter{class: ("rebus-#{[sol_content.to_s.length, 4].min}" if sol_content.to_s.length > 1)}= sol_content
              - else
                .letter
              - cell = @cells[i]
              - if cell.circled
                .circle
              - if cell.cell_num
                .cell-num
          -else
            %td.cell.void{:'data-row' => r, :'data-col' => c}
          - i += 1

  -# Solve Clue Columns
  - edit = false
  -# Across Clues
  = render(partial: 'clues/partials/clue_column', locals: {across: true, edit: edit})
  -# Down Clues
  = render(partial: 'clues/partials/clue_column', locals: {across: false, edit: edit})