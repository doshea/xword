%table
  %thead
    %tr
      %th ID
      %th Title
      %th Creator
      %th Description
      %th Rows
      %th Columns
      %th Letters
      %th Circled?
      %th
      %th
  %tbody
    - @crosswords.each do |crossword|
      = content_tag(:tr, id: dom_id(crossword)) do
        %td= link_to crossword.id, crossword
        %td= link_to crossword.title, crossword
        %td= crossword.user ? link_to(crossword.user.username, crossword.user) : '[deleted]'
        %td.xw-admin-cell--compact= crossword.description
        %td= crossword.rows
        %td= crossword.cols
        %td.xw-admin-cell--compact= crossword.letters
        %td
          - if crossword.circled?
            = icon('check')
        %td
          = link_to edit_admin_crossword_path(crossword) do
            = icon('pencil')
        %td
          / Replaced: link_to with method: :delete, remote: true → turbo_method: :delete (redirect after destroy)
          = link_to admin_crossword_path(crossword), data: { turbo_method: :delete, turbo_confirm: "Are you SURE you want to delete '#{crossword.title}' by #{crossword.user&.username || '[deleted]'}?" } do
            = icon('trash-2')
