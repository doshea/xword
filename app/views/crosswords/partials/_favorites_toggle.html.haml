/ Favorites toggle buttons — extracted as partial so favorite_unfavorite.turbo_stream.erb can re-render them
/ after a favorite or unfavorite action to swap visibility between the two buttons
= link_to(favorite_crossword_path(crossword), title: 'Favorite', class: "xw-btn xw-btn--sm xw-btn--secondary#{(current_user.favorites.include? crossword) ? ' hidden' : ''}", id: 'favorite', data: { turbo_method: :post }) do
  = icon('star')
= link_to(favorite_crossword_path(crossword), title: 'Unfavorite', class: "xw-btn xw-btn--sm xw-btn--secondary#{(current_user.favorites.include? crossword) ? '' : ' hidden'}", id: 'unfavorite', data: { turbo_method: :delete }) do
  = icon('star', style: 'color: #ff7878;')
