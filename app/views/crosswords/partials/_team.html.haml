= javascript_include_tag 'actioncable'
- solver_id = (0..5).map{random_char}.join('')
- display_name = @current_user ? (@current_user.first_name || @current_user.username) : 'anon_'+solver_id
:javascript
  var team_key = "#{@solution.key}";
  team_app = {};
  team_app.display_name = "#{display_name}";
  team_app.solver_id = "#{solver_id}";

= javascript_include_tag 'crosswords/team_funcs', 'data-turbo-track': 'reload'

%dialog#team-explanation.xw-modal{data: {controller: 'modal', action: 'click->modal#clickOutside'}}
  %button.xw-modal__close{data: {action: 'click->modal#close'}, aria: {label: 'Close'}} &times;
  %h2
    = icon('users')
    Crosswords: More Fun as a Team
  %p.team-modal__body
    Solve puzzles with your friends in
    %strong real-time
    &mdash; just send them the link to this puzzle!
  .team-modal__url-row{data: {controller: 'copy-link'}}
    %input.team-modal__url-input{value: request.original_url, readonly: 'readonly', autofocus: true, data: {'copy-link-target': 'input', action: 'click->copy-link#copy'}}
    %button.team-modal__url-copy{type: 'button', data: {'xw-tooltip': 'Copy link', 'copy-link-target': 'button', action: 'click->copy-link#copy'}, aria: {label: 'Copy link'}}= icon('link')
  %p.team-modal__footnote Now to find some friends&hellip;

#team-chat.down
  .row-topper.no-select
    %span#unread-chat-count
    Team Chat
    %span#chat-minmax= icon('chevron-up')
  #chats
  / Replaced: form_tag with remote: true → form_with (Turbo handles AJAX)
  / Wrapped in #team-chat-form so send_team_chat.turbo_stream.erb can replace it to reset the form
  / Extracted to partial so turbo_stream can re-render a blank copy
  #team-chat-form
    = render partial: 'crosswords/partials/team_chat_form', locals: { solution: @solution, display_name: display_name }