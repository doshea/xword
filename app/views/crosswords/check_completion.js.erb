// NOTE: Intentionally kept as .js.erb (not migrated to Turbo Stream).
// Called via $.ajax({ dataType: 'script' }) from solve_funcs.js — Turbo does not intercept this.
if(<%= @correctness %>){
  var win_modal = $('#win-modal');
  if(!win_modal.attr('filled')){
    win_modal.prepend("<%=j render partial: 'solutions/partials/win_modal_contents' %>");
    win_modal.attr('filled', true);
  }
  document.getElementById('win-modal').showModal();
} else {
  alert("Your solution contains incorrect letters.");
}