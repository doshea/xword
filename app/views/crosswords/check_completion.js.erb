// Legacy fallback — primary client uses JSON (dataType: 'json') since the
// globalEval path (dataType: 'script') silently swallows runtime errors and
// triggers jQuery's error callback with status 200.
if(<%= @correctness %>){
  var win_modal = $('#win-modal');
  if(!win_modal.attr('filled')){
    win_modal.prepend("<%=j render partial: 'solutions/partials/win_modal_contents' %>");
    win_modal.attr('filled', true);
  }
  document.getElementById('win-modal').showModal();
} else {
  cw.flash('Your solution contains incorrect letters.', 'warning');
}