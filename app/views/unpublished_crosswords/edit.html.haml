- title @unpublished_crossword.title, true
= content_for :head do
  = stylesheet_link_tag :crossword
  = stylesheet_link_tag :edit
  = javascript_include_tag 'edit', 'data-turbo-track': 'reload'
  = javascript_include_tag 'jquery-ui-1.10.4.draggable.min'
:javascript
  edit_app.circles = '#{@unpublished_crossword.circles}'
:css
  .clue-column .clues {
    height: #{@unpublished_crossword.rows * 2.175 - 22/16.0}em;
  }

%header.xw-container.xw-grid#credit-area
  .xw-col-full
    .xw-edit-header
      %label.xw-edit-header__label{for: 'title'} Title:
      .xw-edit-header__title
        = text_field_tag 'title', @unpublished_crossword.title
        %i#title-status
      #puzzle-controls
        %span#save-status.smaller No changes yet
        %span#save-clock.smaller
        %a#edit-save.xw-btn.xw-btn--sm.xw-btn--secondary{href: '#', title: 'Quicksave', aria: {label: 'Quicksave'}}
          = icon('save')

%section.xw-container.xw-grid#solve-area{aria: {label: 'Edit puzzle grid'}}
  .xw-col-full
    = render partial: 'unpublished_crosswords/partials/edit_unpublished_crossword'

%section.xw-container.xw-grid#meta-area
  .xw-col-full
    .xw-field
      %label.xw-label{for: 'description'} Description
      = text_area_tag :description, @unpublished_crossword.description, class: 'xw-textarea', rows: 4, placeholder: "Say something about the making of this crossword — or anything interesting that doesn't spoil the puzzle!"
  %hr
%section.xw-container.xw-grid#advanced{aria: {labelledby: 'advanced-heading'}}
  %h2.xw-col-full#advanced-heading Advanced Controls
  .xw-col-12.xw-lg-6
    %ul.xw-edit-switches
      %li
        = switch_tag @unpublished_crossword, :mirror_voids
      %li
        = switch_tag @unpublished_crossword, :one_click_void, '1-Click voids'
      %li
        = switch_tag @unpublished_crossword, :circle_mode, 'Circle Mode'
      %li
        = switch_tag @unpublished_crossword, :multiletter_mode, 'Multi-Letter'
  .xw-col-12.xw-lg-6.xw-flex.xw-items-end.xw-justify-end
    = link_to('Publish Puzzle', publish_unpublished_crossword_path(@unpublished_crossword), class: 'xw-btn', data: { turbo_confirm: 'Are you sure you want to publish this puzzle?\nPublished puzzles cannot be edited or deleted.' })
-# NON-INLINE ELEMENTS

%section#idea-container.slide-up-container
  = link_to('#ideas', class: 'bottom-button', id: 'ideas-button', data: { turbo: false }) do
    = icon('lightbulb')
    %span.small Notepad
  #ideas
    .xw-grid
      / Replaced: form_tag with remote: true → form_with (Turbo handles AJAX)
      / id="ideas-input" added so add_potential_word.turbo_stream.erb can clear the field after add
      = form_with(url: add_potential_word_unpublished_crossword_path(@unpublished_crossword), method: :patch) do |f|
        = text_field_tag :word, nil, id: 'ideas-input', autocomplete: 'off', placeholder: "Type a word you're considering"
    / id="ideas-error" added so add_potential_word.turbo_stream.erb can show duplicate-word error
    %p#ideas-error.hidden
    / id="potential-words-list" added so add_potential_word.turbo_stream.erb can replace the full sorted list
    %ul#potential-words-list
      - @unpublished_crossword.potential_words.sort_by { |w| -w.length }.each do |word|
        = render partial: 'unpublished_crosswords/partials/potential_word', locals: {word: word}

%section#pattern-container.slide-up-container
  = link_to('#pattern_search', class: 'bottom-button', id: 'pattern-search-button', data: { turbo: false }) do
    = icon('search')
    %span.small
      Pattern Search
  #pattern-search
    .xw-grid
      / Replaced: form_tag with remote: true → form_with (Turbo handles AJAX)
      = form_with(url: match_words_path, method: :post) do |f|
        = text_field_tag :pattern, nil, id: nil, autocomplete: 'off', placeholder: "e.g. P_TT_RN or SE?RCH"
      #word-match-results

= link_to('#edit-settings', class: 'dark-shadow side-button', id: 'settings-button', data: { turbo: false }) do
  = icon('settings')


%dialog#edit-settings.xw-modal{data: {controller: 'modal', action: 'click->modal#clickOutside'}, aria: {labelledby: 'settings-heading'}}
  %button.xw-modal__close{data: {action: 'click->modal#close'}, aria: {label: 'Close'}} ×
  %h2#settings-heading
    = icon('settings')
    Edit Settings
  %p.settings-modal__placeholder Settings coming soon.