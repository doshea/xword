- title @unpublished_crossword.title, true
= content_for :head do
  = stylesheet_link_tag :crossword
  = stylesheet_link_tag :edit
  = javascript_include_tag 'edit', 'data-turbo-track': 'reload'
:javascript
  edit_app.circles = #{@unpublished_crossword.circles.to_json};
:css
  .clue-column .clues {
    height: #{@unpublished_crossword.rows * 2.175 - 22/16.0}em;
  }
  @media (min-width: 1280px) {
    .clue-column .clues {
      height: #{@unpublished_crossword.rows * 2.61 - 22/16.0}em;
    }
  }

%header.xw-container.xw-grid#credit-area
  .xw-col-full
    .xw-edit-header
      %label.xw-edit-header__label{for: 'title'} Title:
      .xw-edit-header__title
        = text_field_tag 'title', @unpublished_crossword.title, autocomplete: 'off'
        %span#title-status
      #puzzle-controls
        %span#save-status.smaller No changes yet
        %span#save-clock.smaller
        %button#edit-save.xw-btn.xw-btn--sm.xw-btn--ghost{type: 'button', data: {'xw-tooltip': 'Save'}, aria: {label: 'Save'}}
          = icon('save')
        %button#edit-help-button.xw-btn.xw-btn--sm.xw-btn--ghost{type: 'button', data: {'xw-tooltip': 'How to Edit'}, aria: {label: 'How to edit'}}
          = icon('info')

%section.xw-container.xw-grid#solve-area{aria: {label: 'Edit puzzle grid'}}
  .xw-col-full
    = render partial: 'unpublished_crosswords/partials/edit_unpublished_crossword'

%section.xw-container.xw-grid#meta-area{aria: {label: 'Puzzle details'}}
  .xw-col-full
    .xw-field
      %label.xw-label{for: 'description'} Description
      = text_area_tag :description, @unpublished_crossword.description, class: 'xw-textarea', autocomplete: 'off', rows: 4, placeholder: "Say something about the making of this crossword — or anything interesting that doesn't spoil the puzzle!"
%section.xw-container.xw-grid#advanced{aria: {labelledby: 'advanced-heading'}}
  %h2.xw-col-full#advanced-heading Advanced Controls
  .xw-col-12.xw-lg-6
    %ul.xw-edit-switches
      %li
        = switch_tag @unpublished_crossword, :mirror_voids
      %li
        = switch_tag @unpublished_crossword, :one_click_void, '1-Click voids'
      %li
        = switch_tag @unpublished_crossword, :circle_mode, 'Circle Mode'
      %li
        = switch_tag @unpublished_crossword, :multiletter_mode, 'Multi-Letter'
  .xw-col-12.xw-lg-6.xw-flex.xw-items-end.xw-justify-end
    = button_to('Publish Puzzle', publish_unpublished_crossword_path(@unpublished_crossword), method: :patch, class: 'xw-btn', data: { turbo_confirm: 'Are you sure you want to publish this puzzle?\nPublished puzzles cannot be edited or deleted.', disable_with: 'Publishing\u2026' })
-# NON-INLINE ELEMENTS

%section#idea-container.slide-up-container
  %button.bottom-button#ideas-button{type: 'button'}
    = icon('lightbulb')
    %span.small Notepad
  #ideas
    .xw-grid
      / Replaced: form_tag with remote: true → form_with (Turbo handles AJAX)
      / id="ideas-input" added so add_potential_word.turbo_stream.erb can clear the field after add
      = form_with(url: add_potential_word_unpublished_crossword_path(@unpublished_crossword), method: :patch) do |f|
        = text_field_tag :word, nil, id: 'ideas-input', autocomplete: 'off', placeholder: "Type a word you're considering", aria: {label: 'Add word to notepad'}
    / id="ideas-error" added so add_potential_word.turbo_stream.erb can show duplicate-word error
    %p#ideas-error.hidden
    / id="potential-words-list" added so add_potential_word.turbo_stream.erb can replace the full sorted list
    %ul#potential-words-list
      - @unpublished_crossword.potential_words.sort_by { |w| -w.length }.each do |word|
        = render partial: 'unpublished_crosswords/partials/potential_word', locals: {word: word}

%section#pattern-container.slide-up-container
  %button.bottom-button#pattern-search-button{type: 'button'}
    = icon('search')
    %span.small
      Pattern Search
  #pattern-search
    .xw-grid
      / Replaced: form_tag with remote: true → form_with (Turbo handles AJAX)
      = form_with(url: match_words_path, method: :post, data: { controller: 'loading', action: 'submit->loading#submit' }) do |f|
        = text_field_tag :pattern, nil, id: nil, autocomplete: 'off', placeholder: "e.g. P_TT_RN or SE?RCH", aria: {label: 'Pattern search'}
        = submit_tag 'Search', class: 'hidden', data: { loading_target: 'button' }
      #word-match-results

%dialog#edit-help-modal.xw-modal{data: {controller: 'modal', action: 'click->modal#clickOutside'}}
  %button.xw-modal__close{data: {action: 'click->modal#close'}, aria: {label: 'Close'}} &times;
  .xw-manual
    %h2.xw-manual__heading How to Edit

    .xw-manual__section
      %h3 Navigation
      %table.xw-manual__table
        %tr
          %td Move between cells
          %td Arrow keys or click a cell
        %tr
          %td Switch direction
          %td
            Press
            %kbd Space
        %tr
          %td Jump to next word
          %td
            Press
            %kbd Tab
        %tr
          %td Jump to next empty cell
          %td
            Press
            %kbd Enter
        %tr
          %td Jump to a specific clue
          %td Click the clue text
        %tr
          %td Deselect cell
          %td
            Press
            %kbd Esc
            or click outside the grid

    .xw-manual__section
      %h3 Filling the Grid
      %table.xw-manual__table
        %tr
          %td Type a letter
          %td Select a cell, then type &mdash; cursor auto-advances
        %tr
          %td Delete a letter
          %td
            %kbd Backspace
            &mdash; if cell is empty, moves back and deletes
        %tr
          %td Toggle a void (black square)
          %td Double-click a cell
        %tr
          %td Toggle void (fast mode)
          %td Turn on "1-Click voids" in Advanced Controls, then single-click
        %tr
          %td Mirror voids
          %td Turn on "Mirror voids" &mdash; toggling a void also toggles its rotational mirror
        %tr
          %td Add a circle
          %td Turn on "Circle Mode" in Advanced Controls, then click cells to toggle circles

    .xw-manual__section
      %h3 Writing Clues
      %table.xw-manual__table
        %tr
          %td Edit a clue
          %td Click a clue in the Across or Down column to focus its text field
        %tr
          %td Clue numbers
          %td Updated automatically when you add or remove voids
        %tr
          %td Saving clues
          %td Clues save with the rest of the puzzle (not individually)

    .xw-manual__section
      %h3 Finding Words
      %table.xw-manual__table
        %tr
          %td Pattern search
          %td
            Open "Pattern Search" at the bottom. Use
            %kbd _
            for unknown letters (e.g.,
            %code P_ZZ_E
            finds PUZZLE)
        %tr
          %td Notepad
          %td Open "Notepad" to save potential words. Words are sorted by length.

    .xw-manual__section
      %h3 Saving & Publishing
      %table.xw-manual__table
        %tr
          %td Manual save
          %td Click the save icon in the toolbar
        %tr
          %td Auto-save
          %td Your puzzle saves automatically every 15 seconds when you make changes
        %tr
          %td Title & description
          %td These save immediately when you click away from the field
        %tr
          %td Publish
          %td
            Click "Publish Puzzle" when your grid is complete.
            %strong Published puzzles cannot be edited.

    .xw-manual__section
      %h3 Advanced Controls
      %table.xw-manual__table
        %tr
          %td Mirror voids
          %td Void toggles are mirrored rotationally (standard crossword symmetry)
        %tr
          %td 1-Click voids
          %td Single-click toggles voids instead of requiring double-click
        %tr
          %td Circle Mode
          %td Click cells to add/remove circle markers (used for themed puzzles)
