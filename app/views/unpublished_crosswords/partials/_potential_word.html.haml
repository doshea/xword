/ id="potential-word-#{word.downcase}" added so remove_potential_word.turbo_stream.erb can target this element
%li.word{id: "potential-word-#{word.downcase}", data: {length: word.length, word: word}}
  .xw-grid{style: 'margin: 0 auto;'}
    .length.xw-col-1 (#{word.length})
    .xw-col-10= word
    .xw-col-1
      / Replaced: link_to with method: :delete, remote: true → turbo_method: :delete (Turbo handles DELETE)
      = link_to remove_potential_word_unpublished_crossword_path(@unpublished_crossword, word), data: { turbo_method: :delete }, aria: { label: "Remove #{word} from word list" } do
        = icon('x')