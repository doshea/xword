= form_for @ucw do |f|
  %fieldset.borderless
    .xw-grid
      .xw-col-12.xw-lg-8
        =f.label :title
        -# # =text_field_tag 'crossword[title]', nil, placeholder: 'Untitled', required: true
        =f.text_field :title, placeholder: 'Untitled', required: true
      .xw-col-12.xw-lg-2
        =f.label :rows
        =f.number_field :rows, min: 4, max: 30
      .xw-col-12.xw-lg-2
        =f.label :cols
        =f.number_field :cols, min: 4, max: 30
    .xw-grid
      .xw-col-full
        =f.label :description
        =f.text_area :description
        =f.submit 'Create Crossword', class: 'button success'