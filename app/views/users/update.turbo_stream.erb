<%# Turbo Stream: replaces profile picture in photo section and header avatar %>
<%= turbo_stream.replace "profile-pic" do %>
  <%= image_tag @user.image.url, id: "profile-pic", alt: @user.display_name, class: "profile-pic-updateable" %>
<% end %>
<%= turbo_stream.replace "header-pic" do %>
  <%= image_tag @user.image.url, id: "header-pic", alt: @user.display_name %>
<% end %>
