-# Account header — identity banner
.xw-col-full
  .xw-account-header
    .xw-account-header__avatar
      = image_tag user.image.url, id: 'header-pic', alt: user.display_name
    .xw-account-header__info
      %h1.xw-account-header__name= user.display_name
      %p.xw-account-header__meta
        Member since
        %time{datetime: user.created_at.iso8601}= user.created_at.strftime("%B %Y")
        - if user.location.present?
          %span.xw-account-header__dot &middot;
          = user.location

-# ── Section 1: Profile ──
.xw-col-full
  = form_with model: user, html: { multipart: true } do |f|
    %section.xw-account-section
      %h2.xw-account-section__heading Profile Photo
      .xw-account-photo
        .xw-account-photo__preview
          = image_tag user.image.url, id: 'profile-pic', alt: user.display_name
        .xw-account-photo__controls
          .xw-field
            %label.xw-label{for: 'user_image'} Upload from your computer
            = f.file_field :image, class: 'xw-input xw-input--file', id: 'user_image'
          .xw-account-photo__divider
            %span or
          .xw-field
            %label.xw-label{for: 'user_remote_image_url'} Paste an image URL
            = url_field_tag "user[remote_image_url]", nil, placeholder: "https://example.com/photo.jpg", class: 'xw-input', id: 'user_remote_image_url'

    %section.xw-account-section
      %h2.xw-account-section__heading Personal Info
      .xw-account-form-grid
        .xw-field
          = f.label :first_name, 'First Name', class: 'xw-label'
          = f.text_field :first_name, placeholder: 'Will', maxlength: User::MAX_FIRST_NAME_LENGTH, autocomplete: 'given-name', class: 'xw-input'
        .xw-field
          = f.label :last_name, 'Last Name', class: 'xw-label'
          = f.text_field :last_name, placeholder: 'Shortz', maxlength: User::MAX_LAST_NAME_LENGTH, autocomplete: 'family-name', class: 'xw-input'
      .xw-account-form-grid
        .xw-field
          = f.label :email, 'Email', class: 'xw-label'
          = f.email_field :email, maxlength: User::MAX_EMAIL_LENGTH, autocomplete: 'email', class: 'xw-input'
        .xw-field
          = f.label :username, 'Username', class: 'xw-label'
          = f.text_field :username, maxlength: User::MAX_USERNAME_LENGTH, autocomplete: 'username', class: 'xw-input'
      .xw-field
        = f.label :location, 'Location', class: 'xw-label'
        = f.text_field :location, placeholder: 'Lost in thought', class: 'xw-input'
      .xw-account-section__actions
        = f.submit 'Update Profile', class: 'xw-btn', data: { disable_with: 'Updating\u2026' }

-# ── Section 2: Notifications ──
.xw-col-full
  = form_with model: user do |f|
    %section.xw-account-section
      %h2.xw-account-section__heading In-App Notifications
      %p.xw-account-section__hint
        These control the notifications you see on this site (the bell icon in the nav bar).
        They do not affect emails. To stop receiving emails, use the unsubscribe link at the
        bottom of any email.
      .xw-account-notification-list
        - notification_labels = { 'friend_request' => 'Friend requests',
            'friend_accepted' => 'Friend request accepted',
            'puzzle_invite' => 'Puzzle invitations',
            'comment_on_puzzle' => 'Comments on your puzzles',
            'comment_reply' => 'Replies to your comments' }
        - notification_labels.each do |type, label|
          .xw-account-notification-item
            = hidden_field_tag "user[notification_preferences][#{type}]", '0', id: nil
            = check_box_tag "user[notification_preferences][#{type}]", '1', !user.notification_muted?(type), id: "notif_#{type}", class: 'xw-checkbox'
            = label_tag "notif_#{type}", label, class: 'xw-checkbox-label'
      .xw-account-section__actions
        = f.submit 'Save Preferences', class: 'xw-btn', data: { disable_with: 'Saving\u2026' }

-# ── Section 3: Account ──
.xw-col-full
  %section.xw-account-section
    %h2.xw-account-section__heading Change Password
    #password-errors.xw-alert.xw-alert--error.hidden
      %p
      %button.slide-close{type: 'button', aria: {label: 'Dismiss error'}} ×
    = form_with(url: change_password_users_path, method: :post) do |f|
      .xw-field
        %label.xw-label{for: 'old_password'} Current Password
        = password_field_tag :old_password, nil, placeholder: 'Enter current password', required: true, autocomplete: 'current-password', class: 'xw-input', id: 'old_password'
      .xw-field
        %label.xw-label{for: 'new_password'} New Password
        = password_field_tag :new_password, nil, placeholder: 'Choose a new password', required: true, maxlength: User::MAX_PASSWORD_LENGTH, autocomplete: 'new-password', class: 'xw-input', id: 'new_password'
      .xw-field
        %label.xw-label{for: 'new_password_confirmation'} Confirm New Password
        = password_field_tag :new_password_confirmation, nil, placeholder: 'Re-enter new password', required: true, maxlength: User::MAX_PASSWORD_LENGTH, autocomplete: 'new-password', class: 'xw-input', id: 'new_password_confirmation'
      .xw-account-section__actions
        = submit_tag 'Change Password', class: 'xw-btn', data: {disable_with: 'Changing\u2026'}

.xw-col-full
  %section.xw-account-section.xw-account-section--danger
    %h2.xw-account-section__heading Delete Account
    %p.xw-account-section__hint
      This will permanently anonymize your account. Your puzzles and comments will remain
      but show as "[Deleted Account]". Your solve history and friendships will be removed.
      This cannot be undone.
    = link_to 'Delete My Account', delete_account_users_path, class: 'xw-btn xw-btn--danger', data: { turbo_method: :delete, turbo_confirm: 'Are you SURE you want to delete your account? Your puzzles and comments will remain but be anonymized. This cannot be undone.' }
