-# Hero card — full-width within the .xw-grid parent
.xw-col-full
  .xw-profile-hero
    .xw-profile-hero__avatar
      = image_tag @user.image.search.url, alt: @user.display_name
    .xw-profile-hero__info
      %h1.xw-profile-hero__name= @user.display_name
      %p.xw-profile-hero__joined
        Member since
        %time{datetime: @user.created_at.iso8601}= @user.created_at.strftime("%B %Y")
      - if @user.location.present?
        %p.xw-profile-hero__location= @user.location
      - if @own_profile
        = link_to account_users_path, class: 'xw-btn xw-btn--ghost xw-btn--sm xw-profile-hero__edit' do
          = icon('settings', size: 14)
          Edit Profile
      - elsif @current_user
        = render partial: 'users/partials/friend_status',
                 locals: { user: @user, status: @friend_status }
    .xw-profile-hero__stats
      .xw-profile-stat
        %span.xw-profile-stat__number= @solved_count
        %span.xw-profile-stat__label Solved
      .xw-profile-stat
        %span.xw-profile-stat__number= @crossword_count
        %span.xw-profile-stat__label Created
      - if @own_profile
        .xw-profile-stat
          %span.xw-profile-stat__number= @in_progress_count
          %span.xw-profile-stat__label In Progress
      .xw-profile-stat
        %span.xw-profile-stat__number= @clues_count
        %span.xw-profile-stat__label Clues Written

-# Puzzles card — full width, above comments
.xw-col-full
  %section.xw-profile-card
    %h2.xw-profile-card__heading Puzzles
    - if @crosswords.any?
      .xw-profile-puzzles
        - @crosswords.each do |cw|
          = link_to cw, class: 'xw-profile-puzzle' do
            - if cw.preview.url
              = image_tag cw.preview.url, class: 'xw-profile-puzzle__thumb', alt: cw.title
            - else
              .xw-profile-puzzle__thumb.xw-profile-puzzle__thumb--empty
            %span.xw-profile-puzzle__title= cw.title
      = will_paginate @crosswords, class: 'xw-pagination', param_name: 'puzzles_page'
    - else
      %p.xw-profile-card__empty No puzzles created yet.

-# Comments card — full width, below puzzles
.xw-col-full
  %section.xw-profile-card
    %h2.xw-profile-card__heading Recent Comments
    - if @comments.any?
      %ul.xw-profile-comments
        - @comments.each do |c|
          - cw = c.base_crossword
          %li.xw-profile-comment
            %span.xw-profile-comment__text= c.content
            %span.xw-profile-comment__meta
              %time{datetime: c.created_at.iso8601}= c.created_ago
              - if cw
                %span.xw-profile-comment__dot &middot;
                = link_to cw.title, cw
      = will_paginate @comments, class: 'xw-pagination', param_name: 'comments_page'
    - else
      %p.xw-profile-card__empty No comments yet.
