- title 'Admin | Edit Clue', true
= render layout: 'layouts/partials/admin_page', locals: {page_title: 'Edit Clue', back_path: admin_clues_path} do
  = render 'shared/form_errors', object: @clue
  .xw-admin-form
    = form_with model: @clue, url: url_for(controller: 'admin/clues', action: :update), html: { class: 'xw-grid' } do |f|
      .xw-col-12.xw-lg-11
        .xw-field
          = f.label :content, class: 'xw-label'
          = f.text_field :content, class: 'xw-input'
      .xw-col-12.xw-lg-1
        .xw-field
          = f.label :difficulty, class: 'xw-label'
          = f.number_field :difficulty, class: 'xw-input'
      .xw-col-full
        = f.submit class: 'xw-btn xw-btn--success', data: {disable_with: 'Updating...'}
