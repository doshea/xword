- title 'Admin | Edit Clue', true
= render layout: 'layouts/partials/admin_page', locals: {page_title: 'Edit Clue', back_path: admin_clues_path} do
  .xw-admin-form
    = form_with model: @clue, url: url_for(controller: 'admin/clues', action: :update), html: { class: 'xw-grid' } do |f|
      .xw-col-12.xw-lg-11
        = f.label :content
        = f.text_field :content
      .xw-col-12.xw-lg-1
        = f.label :difficulty
        = f.number_field :difficulty
      .xw-col-full
        = f.button class: 'xw-btn xw-btn--success', data: {disable_with: 'Updating...'}
