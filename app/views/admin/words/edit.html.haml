= render layout: 'layouts/partials/topper_stopper', locals: {row_top_title: "Edit Word", custom_columns: true} do
  %br
  / Replaced: form_for with remote: true → form_with (Turbo handles AJAX; controller now redirects after update)
  = form_with model: @word, url: url_for(controller: 'admin/words', method: :update), html: { class: 'xw-col-full xw-grid' } do |f|
    .xw-col-full
      = f.label :content
      = f.text_field :content
    .xw-col-full
      = f.submit class: 'xw-btn xw-btn--success', data: {disable_with: 'Updating...'}