- title 'Admin | Edit Comment', true
= render layout: 'layouts/partials/admin_page', locals: {page_title: 'Edit Comment', back_path: admin_comments_path} do
  = render 'shared/form_errors', object: @comment
  .xw-admin-form
    = form_with model: @comment, url: url_for(controller: 'admin/comments', action: :update), html: { class: 'xw-grid' } do |f|
      .xw-col-12.xw-lg-8
        .xw-field
          = f.label :content, class: 'xw-label'
          = f.text_field :content, class: 'xw-input'
      .xw-col-12.xw-lg-4
        .xw-field.xw-field--inline
          = f.check_box :flagged, class: 'xw-checkbox'
          = f.label :flagged, class: 'xw-checkbox-label'
      .xw-col-full
        = f.submit class: 'xw-btn xw-btn--success', data: {disable_with: 'Updating...'}
