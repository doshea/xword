%table.xw-admin-table
  %thead
    %tr
      %th ID
      %th Content
      %th Word
      %th Difficulty
      %th
  %tbody
    - @clues.each do |clue|
      = content_tag(:tr, id: dom_id(clue)) do
        %td= link_to clue.id, clue
        %td= link_to clue.content, clue
        %td= clue.word.content if clue.word
        %td= clue.difficulty
        %td.xw-admin-actions
          = link_to edit_admin_clue_path(clue), class: 'xw-admin-action' do
            = icon('pencil')
          = link_to admin_clue_path(clue), class: 'xw-admin-action xw-admin-action--danger', data: { turbo_method: :delete, turbo_confirm: "Are you SURE you want to delete this clue?" } do
            = icon('trash-2')
