- title 'Create'
= render layout: 'layouts/partials/topper_stopper', locals: {columns_class: 'xw-puzzle-grid', row_top_title: 'Your Puzzles'} do

  -# --- Unpublished puzzles ---
  %section
    %h2.xw-create__section-heading
      Unpublished
      %span.xw-create__count= @unpublished.count
    - if @unpublished.any?
      %ul
        - @unpublished.each do |cw|
          %li
            = render partial: 'crosswords/partials/crossword_tab', locals: {cw: cw, unpublished: true}
    - else
      .xw-empty-state
        = icon('clipboard-pen', size: 36, class: 'xw-empty-state__icon')
        %p.xw-empty-state__heading No puzzles in progress
        %p Start creating! Your unpublished puzzles will appear here.
    .xw-create__new-btn
      = link_to new_unpublished_crossword_path, class: 'xw-btn xw-btn--success' do
        = icon('pencil')
        New Puzzle

  -# --- Published puzzles ---
  - if @published.any?
    %hr
    %section
      %h2.xw-create__section-heading
        Published
        %span.xw-create__count= @published.count
      %ul
        - @published.each do |cw|
          %li
            = render partial: 'crosswords/partials/crossword_tab', locals: {cw: cw}
