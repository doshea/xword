%table.xw-admin-table
  %thead
    %tr
      %th ID
      %th Content
      %th Example Clue
      %th
  %tbody
    - @words.each do |word|
      = content_tag(:tr, id: dom_id(word)) do
        %td= link_to word.id, word
        %td= link_to word.content, word
        %td= word.clues.first.try(:content)
        %td.xw-admin-actions
          = link_to edit_admin_word_path(word), class: 'xw-admin-action' do
            = icon('pencil')
          = link_to admin_word_path(word), class: 'xw-admin-action xw-admin-action--danger', data: { turbo_method: :delete, turbo_confirm: "Are you SURE you want to delete #{word.content}?" } do
            = icon('trash-2')
