= content_tag(:article, id: dom_id(reply), class: 'xw-reply') do
  .xw-reply__avatar
    = link_to (image_tag reply.user.image.reply_size.url), reply.user
    - if @current_user && ((@current_user == reply.user) || (@current_user.is_admin?))
      .reply-controls
        %a
          = icon('pencil')
        / Replaced: link_to with method: :delete, remote: true → turbo_method: :delete (Turbo handles DELETE)
        = link_to reply, class: 'reply-controls__delete', data: { turbo_method: :delete, turbo_confirm: 'Are you SURE you want to delete this reply?' } do
          = icon('trash-2')
  .xw-reply__body
    %p= reply.content
