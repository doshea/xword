.xw-container.row-bookend.row-topper
  - if defined?(row_top_title)
    %h4
      = row_top_title
.xw-container.xw-grid{style: defined?(row_style) ? row_style : nil, class: defined?(row_class) ? row_class : nil}
  - unless defined?(custom_columns)
    .xw-col-full{style: defined?(columns_style) ? columns_style : nil, class: defined?(columns_class) ? columns_class : nil}
      = yield
  - else
    = yield
.xw-container.row-bookend.row-stopper