- if @current_user
  - if @solved.any?
    - solved_initial = @solved[0...Crossword.per_page]
    %ul
      - solved_initial.each do |cw|
        %li
          = render partial: 'crosswords/partials/crossword_tab', locals: {cw: cw}

    - solved_remaining = @solved[Crossword.per_page..-1]
    - if solved_remaining && solved_remaining.any?
      .center
        = render partial: 'pages/home/load_next_button', locals: {remaining: solved_remaining}
  - else
    %p You haven't finished any puzzles yet -- go check out the New tab and try one!
- else
  %p Make an account or log in and you'll be able to track which crosswords you've finished!
