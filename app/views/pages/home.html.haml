- title 'Home'
-# TODO: FIX UP THE SEARCH.CSS FILE SO IT DOESN'T CONTAIN THIS SORT OF GLOBAL CSS
= content_for :head do
  = stylesheet_link_tag :search

= render layout: 'layouts/partials/topper_stopper', locals: {columns_class: 'xw-puzzle-grid'} do
  %h1.xw-home__heading
    - if @current_user
      Welcome back, #{@current_user.display_first_name}!
    - else
      Welcome to the Café!
  .xw-tabs{data: {controller: 'tabs'}}
    .xw-tabs__nav
      = link_to '#panel1', class: 'xw-tab xw-tab--active', data: {tabs_target: 'tab', action: 'click->tabs#show'} do
        %span.tab-label
          = icon('clipboard')
          %span #{'New' if @current_user} Puzzles (#{@unstarted_count})
      - if @current_user
        = link_to '#panel2', class: 'xw-tab', data: {tabs_target: 'tab', action: 'click->tabs#show'} do
          %span.tab-label
            = icon('clipboard-pen')
            %span In Progress (#{@in_progress_count})
        = link_to '#panel3', class: 'xw-tab', data: {tabs_target: 'tab', action: 'click->tabs#show'} do
          %span.tab-label
            = icon('clipboard-list')
            %span Solved Puzzles (#{@solved_count})
    .xw-tab-panels
      #panel1.xw-tab-panel.xw-tab-panel--active{data: {tabs_target: 'panel'}}
        = render partial: 'pages/home/unstarted'
      #panel2.xw-tab-panel{data: {tabs_target: 'panel'}}
        = render partial: 'pages/home/in_progress'
      #panel3.xw-tab-panel{data: {tabs_target: 'panel'}}
        = render partial: 'pages/home/solved_puzzles'
