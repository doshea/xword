= render layout: 'layouts/partials/topper_stopper', locals: {custom_columns: true} do
  .xw-col-12.xw-md-center-4
    = image_tag 'error.png', class: 'xw-error-image', alt: 'Error illustration'
  .xw-col-full
    .xw-prose
      %h1.center
        - if flash[:error]
          = flash[:error]
        - else
          Something went wrong.
      %p.center
        = link_to 'Back to puzzles', root_path, class: 'xw-btn'
