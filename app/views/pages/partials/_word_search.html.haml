%h2.search-result-count= "#{pluralize(@words.count, 'word')}  found"

%table
  %thead
    %tr
      %th
        Word
      %th
        Clues
      %th
        Used in
  %tbody
    - @words.each do |word|
      %tr
        %td
          = word.content
        %td
          = word.clues.count
        %td
          = word.crosswords.count